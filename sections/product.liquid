<link
  rel="stylesheet"
  type="text/css"
  href="//cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css" />
<script
  type="text/javascript"
  src="//cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"
  defer></script>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />

<script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>


<div class="pro-breadcrumbs">
  <div class="container">
      <div class="bcrum-in">
        <ul>
          <li><a href="{{ routes.root_url }}">Home</a></li>

          {%- liquid
            assign selected_col = nil
            # Define the handles you want to skip
            assign generic_handles = "all,all-products,all-fruits,all-fruit,all-collections,shop-all,alle-produkte,alle-fruchte,alle-fruechte,tous-les-produits,tous-les-fruits,frontpage,best-seller" | split: ","
            
            # 1. Check if we are currently in a valid collection
            if collection
              assign is_generic = false
              if generic_handles contains collection.handle or collection.handle contains 'all-' or collection.handle contains 'alle-' or collection.handle contains 'tous-les-'
                assign is_generic = true
              endif

              if is_generic == false
                assign selected_col = collection
              endif
            endif

            # 2. If no collection selected yet, loop through product collections
            if selected_col == nil
              for col in product.collections
                if generic_handles contains col.handle or col.handle contains 'all-' or col.handle contains 'alle-' or col.handle contains 'tous-les-'
                  continue
                else
                  assign selected_col = col
                  break
                endif
              endfor
            endif
          -%}

          {%- if selected_col -%}
            <li>
              <a href="{{ selected_col.url }}">
                {{ selected_col.title }}
              </a>
            </li>
          {%- endif -%}

          <li>
            <span>{{ product.title }}</span>
          </li>
        </ul>
      </div>
  </div>
</div>

{% assign default_variant = nil %}

{% for variant in product.variants %}
  {% if variant.metafields.custom.is_prior == true and variant.available %}
    {% assign default_variant = variant %}
    {% break %}
  {% endif %}
{% endfor %}

{% if default_variant == nil %}
  {% for variant in product.variants %}
    {% if variant.available %}
      {% assign default_variant = variant %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if default_variant == nil %}
  {% assign default_variant = product.variants.first %}
{% endif %}

{% assign selected_variant = default_variant %}

<div class="product-info">
  <div class="container">
    <div class="pro-grid">
       <div class="pro-img-wrap">
          <div class="pro-img">
            <div class="pro-right-side">
              <div class="prs-data">
                {% if product.tags.size > 0 or product.metafields.custom.certificate or product.metafields.custom.quality_label != blank %}
                    <div class="fc_category_tags">
                      {% if product.metafields.custom.certificate %}
                        {% assign certificate = product.metafields.custom.certificate.value %}
                        {% for item in product.metafields.custom.certificate.value %}
                          <div class="fc_organic_auth">
                            <img
                              src="{{ item.badge_image | img_url:'master' }}"
                              alt="{{ item.display_name }}"
                              class="img_sizing">
                          </div>
                        {% endfor %}
                      {% endif %}

                      {% if product.metafields.custom.quality_label != blank %}
                        <span>{{ product.metafields.custom.quality_label.value | default: product.metafields.custom.quality_label }}</span>
                      {% endif %}

                      {% comment %}
                        {% for tag in product.tags %}
                          {% unless tag == 'Best Seller' %}
                            <span>{{ tag }}</span>
                          {% endunless %}
                        {% endfor %}
                      {% endcomment %}
                    </div>
                  {% endif %}

                  {% if product.tags contains 'Best Seller' %}
                    <div class="fc_bestsell_tags">
                      <span>Bestseller</span>
                    </div>
                  {% endif %}
              </div>
              <div class="prod-main-image">
                {% if product.media.size > 0 %}
                  {% for media in product.media %}
                    <div class="item" data-media-id="{{ media.id }}">
                      <div class="prod-main">
                        <a href="{{ media | img_url: 'master' }}" 
                          data-fancybox="gallery" 
                          class="zoom-wrapper">
                          {% render 'product-media', media: media %}
                        </a>
                      </div>
                    </div>
                  {% endfor %}
                {% else %}
                  {% comment %} This renders ONLY if there are no images/videos {% endcomment %}
                  <div class="item">
                    <div class="prod-main">
                      <img
                        src="https://cdn.shopify.com/s/files/1/0752/8015/4881/files/jf-placeholder.png?v=1769522647"
                        alt="{{ product.title }}"
                        class="image-custom"
                        loading="lazy">
                    </div>
                  </div>
                {% endif %}
              </div>
              <div class="btn-wrap">
                <button class="custom-prev">
                  {%- render 'arrow-prev' -%}
                </button>
                <button class="custom-next">
                  {%- render 'arrow-next' -%}
                </button>
              </div>
            </div>
            <div class="prod-thumb-image">
              {% if product.media.size > 0 %}
                {% for media in product.media %}
                  <div class="item" data-media-id="{{ media.id }}">
                    <div class="prod-thumb">
                      {% render 'product-media', media: media %}
                    </div>
                  </div>
                {% endfor %}
              {% else %}
                {% comment %} Show a small thumbnail placeholder if no media exists {% endcomment %}
                <div class="item">
                  <div class="prod-thumb">
                    <img
                      src="https://cdn.shopify.com/s/files/1/0752/8015/4881/files/jf-placeholder.png?v=1769522647"
                      alt="Placeholder"
                      class="image-custom thumb-placeholder"
                      loading="lazy">
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
          <div class="pro-test fordesktop">
            {% for block in section.blocks %}
              {% if block.settings.show_testimonial 
                and product.metafields.custom.title_testimonial != blank %}
                {% comment %} <div class="tr-okendo">
                  <p data-oke-star-rating data-oke-reviews-product-id="shopify-{{ product.id }}"></p>
                </div> {% endcomment %}
                <div class="tr-testimonial">
                  {% render 'testimonial-icon' %}
                  {{ product.metafields.custom.title_testimonial | metafield_tag }}
                </div>
              {% endif %}
            {% endfor %}
          </div>
       </div>
      <div class="pro-desp">
        {% form 'product'
          , product
          , id: 'product-form'
          , novalidate: 'novalidate' %}
          <input
            type="hidden"
            name="id"
            value="{{ selected_variant.id }}">

          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'title' %}
                <div class="title">
                  <div class="title-review">
                    {% comment %} {% if block.settings.show_testimonial 
                      and product.metafields.custom.title_testimonial != blank %}
                      <div class="tr-testimonial">
                        {% render 'testimonial-icon' %}
                        {{ product.metafields.custom.title_testimonial | metafield_tag }}
                      </div>
                    {% endif %} {% endcomment %}

                    <!-- OKENDO APP BLOCK BESIDE TESTIMONIAL -->
                    <a href="#" class="review-link">
                    <div class="tr-okendo">
                      <p data-oke-star-rating data-oke-reviews-product-id="shopify-{{ product.id }}"></p>
                    </div>
                    </a>

                    {% assign certificate = product.metafields.custom.certificate %}
                    <div class="tr-review-certi">
                      <div class="ts-certificate">
                        {% if certificate != '' %}
                          {% for item in certificate.value %}
                            <div class="tsc-img">
                              <img src="{{ item.badge_image |  img_url: 'master' }}" alt="{{ item.display_name }}" class="img">
                            </div>
                          {% endfor %}
                        {% endif %}
                      </div>
                    </div>
                  </div>
                  <h1>{{ product.title }}</h1>
                    <div class="price" id="price-{{ section.id }}">
                      <div class="price-detailsss"> 

                        <div class="pd-top">
                          {% assign currency_suffix = cart.currency.symbol %}
                          <div class="sell-price {% unless selected_variant.compare_at_price > selected_variant.price %}withoutbg{% endunless %}">
                            {{ selected_variant.price | money_without_currency }} {{ cart.currency.symbol }}
                          </div>

                          <strike class="real-price">
                            {{ selected_variant.compare_at_price | money_without_currency }} {{ cart.currency.symbol }}
                          </strike>

                          {% if selected_variant.compare_at_price > selected_variant.price %}
                            <span class="off-percent" data-price-off-percent>
                              -{{ selected_variant.compare_at_price | minus: selected_variant.price | times: 100 | divided_by: selected_variant.compare_at_price | round }}%
                            </span>
                          {% endif %}
                        </div>

                        <div class="pd-bottom">
                          <span class="sell-price-variant-perkg">
                            {% if selected_variant.unit_price_measurement %}
                              {{ selected_variant.unit_price | money_without_currency }} {{ cart.currency.symbol }} / {{ selected_variant.unit_price_measurement.reference_unit }}
                            {% else %}
                              {{ selected_variant.price | money_without_currency }} {{ cart.currency.symbol }} / unit
                            {% endif %}
                          </span>
                        </div>
                        <!-- ALWAYS present -->
                      </div>

                      <span class="price-txt">
  {{ 'sections.product.price_includes_vat' | t }} 
  <a href="#" class="shipping-cost-trigger">
    {{ 'sections.product.shipping_costs' | t }}
  </a>
</span>
                    </div>

                </div>

              {% when 'product_usp' %}
                <div class="product-usp">
                  {% for item in product.metafields.custom.product_usp.value %}
                    <div class="pu-item">
                      <div class="pui-icon">
                        <img src="{{ item.usp_icon |  img_url: 'master' }}" alt="{{ item.usp_text }}">
                      </div>
                      <div class="pui-txt">
                        <p>{{ item.usp_text }}</p>
                      </div>
                    </div>
                  {% endfor %}
                </div>

              {% when 'product_info' %}
                {%- if product.metafields.custom.additional_information.value != blank -%}
                <div class="product-info-block">
                  {%- comment -%} Testimonials will still show here if they exist {%- endcomment -%}
                  <div class="pro-test formobile">
                    {% for block in section.blocks %}
                      {% if block.settings.show_testimonial and product.metafields.custom.title_testimonial != blank %}
                        <div class="tr-testimonial">
                          {% render 'testimonial-icon' %}
                          {{ product.metafields.custom.title_testimonial | metafield_tag }}
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>

                  {% for item in product.metafields.custom.additional_information.value %}
                    <div class="pi-item">
                      {% render 'green-tick' %}
                      <div class="pii-info">
                        <p>
                          <strong>{{ item.inforamation_title }}</strong>
                          {{ item.information_paragraph }}
                        </p>
                      </div>
                    </div>
                  {% endfor %}
                </div>
              {%- endif -%}

              {% when 'store_usp' %}
                <div class="store-usp">
                  {% comment %} For Shipping USP {% endcomment %}
                  <div class="su-item">
                    <div class="sui-icon">
                      <img src="{{ block.settings.shipping_usp_icon |  img_url: 'master' }}" alt="{{ block.settings.shipping_usp_text }}">
                    </div>
                    {% comment %} <div class="sui-txt">
                      <a id="delivery-data" href="{{ block.settings.shipping_usp_page.url }}">{{ block.settings.shipping_usp_text }}</a>
                    </div> {% endcomment %}
                    {% comment %} <div class="sui-txt">
                      <a id="delivery-data"href="{{ shop.shipping_policy.url }}">{{ block.settings.shipping_usp_text }}</a>
                    </div> {% endcomment %}
                     <div class="sui-txt">
                        {% comment %} <a id="delivery-data" href="{{ block.settings.shipping_usp_page.url }}"
                          class="shipping-policy-popup"
                          data-modal-target="shipping-modal">
                          {{ block.settings.shipping_usp_text }}
                        </a> {% endcomment %}
                        <span id="delivery-data"
                          role="button"
                          class="shipping-policy-popup usp-modal-trigger"
                          data-modal-target="shipping-modal">
                          {{ block.settings.shipping_usp_text }}
                        </span>
                      </div>

                      <!-- Shipping Policy Modal -->
                      <div id="shipping-modal" class="shipping-modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="shipping-modal-title">
                        <div class="shipping-modal-container">
                          <div class="shipping-modal-header">
                            <h2 id="shipping-modal-title">{{ 'general.shipping_policy' | t | default: 'Shipping Policy' }}</h2>
                            <span class="shipping-modal-close" aria-label="Close modal" role="button" tabindex="0">&times;</span>
                          </div>
                          <div class="shipping-modal-body" data-lenis-prevent>
                            <div class="shipping-modal-content">
                              {{ shop.shipping_policy.body }}
                            </div>
                          </div>
                        </div>
                      </div>

                      <script>
                        (function () {
                          const trigger = document.querySelector('.shipping-policy-popup');
                          const modal   = document.getElementById('shipping-modal');
                          const closeBtn = modal.querySelector('.shipping-modal-close');

                          function openModal(e) {
                            e.preventDefault();
                            modal.classList.add('is-open');
                            modal.setAttribute('aria-hidden', 'false');
                            document.body.style.overflow = 'hidden';
                            closeBtn.focus();
                          }

                          function closeModal() {
                            modal.classList.remove('is-open');
                            modal.setAttribute('aria-hidden', 'true');
                            document.body.style.overflow = '';
                            trigger.focus();
                          }

                          trigger.addEventListener('click', openModal);
                          closeBtn.addEventListener('click', closeModal);

                          // Close on overlay click
                          modal.addEventListener('click', function (e) {
                            if (e.target === modal) closeModal();
                          });

                          // Close on Escape key
                          document.addEventListener('keydown', function (e) {
                            if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
                          });
                        })();
                      </script>
                  </div>

                  {% comment %} For Freshness USP {% endcomment %}
                  {% if product.metafields.custom.fresh_product != true %}

                  {% else %}
                    <div class="su-item">
                      <div class="sui-icon">
                        <img src="{{ block.settings.freshness_icon |  img_url: 'master' }}" alt="{{ 'sections.product.freshness_usp' | t | default: block.settings.freshness_text }}">
                      </div>
                      <div class="sui-txt">
                        <span
                          class="usp-modal-trigger"
                          role="button"
                          tabindex="0"
                          data-modal-target="freshness-modal-{{ section.id }}">
                          {{ 'sections.product.freshness_usp' | t | default: block.settings.freshness_text }}
                        </span>
                      </div>
                    </div>
                  {% endif %}

                  {% comment %} For Payment USP {% endcomment %}
                  <div class="su-item">
                    <div class="sui-icon">
                      <img src="{{ block.settings.payment_usp_icon |  img_url: 'master' }}" alt="{{ 'sections.product.payment_usp' | t | default: block.settings.payment_usp_text }}">
                    </div>
                    <div class="sui-txt">
                      <span
                        class="usp-modal-trigger"
                        role="button"
                        tabindex="0"
                        data-modal-target="payment-modal-{{ section.id }}">
                        {{ 'sections.product.payment_usp' | t | default: block.settings.payment_usp_text }}
                      </span>
                    </div>
                  </div>

                  <div id="freshness-modal-{{ section.id }}" class="shipping-modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="freshness-modal-title-{{ section.id }}">
                    <div class="shipping-modal-container">
                      <div class="shipping-modal-header">
                        <h2 id="freshness-modal-title-{{ section.id }}">{{ 'sections.product.freshness_modal_title' | t }}</h2>
                        <span class="shipping-modal-close" aria-label="Close modal" role="button" tabindex="0">&times;</span>
                      </div>
                      <div class="shipping-modal-body" data-lenis-prevent>
                        <div class="shipping-modal-content">
                          <p>{{ 'sections.product.freshness_modal_body' | t }}</p>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div id="payment-modal-{{ section.id }}" class="shipping-modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="payment-modal-title-{{ section.id }}">
                    <div class="shipping-modal-container">
                      <div class="shipping-modal-header">
                        <h2 id="payment-modal-title-{{ section.id }}">{{ 'sections.product.payment_modal_title' | t }}</h2>
                        <span class="shipping-modal-close" aria-label="Close modal" role="button" tabindex="0">&times;</span>
                      </div>
                      <div class="shipping-modal-body" data-lenis-prevent>
                        <div class="shipping-modal-content">
                          <p>{{ 'sections.product.payment_modal_body' | t }}</p>
                        </div>
                      </div>
                    </div>
                  </div>

                  <script>
                    (function () {
                      document.querySelectorAll('.usp-modal-trigger').forEach(function (trigger) {
                        if (trigger.dataset.uspModalBound === 'true') return;

                        const modal = document.getElementById(trigger.dataset.modalTarget);
                        if (!modal) return;

                        const closeBtn = modal.querySelector('.shipping-modal-close');
                        if (!closeBtn) return;

                        function openModal(e) {
                          e.preventDefault();
                          modal.classList.add('is-open');
                          modal.setAttribute('aria-hidden', 'false');
                          document.body.style.overflow = 'hidden';
                          closeBtn.focus();
                        }

                        function closeModal() {
                          modal.classList.remove('is-open');
                          modal.setAttribute('aria-hidden', 'true');
                          document.body.style.overflow = '';
                          trigger.focus();
                        }

                        trigger.dataset.uspModalBound = 'true';
                        trigger.addEventListener('click', openModal);
                        trigger.addEventListener('keydown', function (e) {
                          if (e.key === 'Enter' || e.key === ' ') openModal(e);
                        });
                        closeBtn.addEventListener('click', closeModal);
                        closeBtn.addEventListener('keydown', function (e) {
                          if (e.key === 'Enter' || e.key === ' ') closeModal();
                        });
                        modal.addEventListener('click', function (e) {
                          if (e.target === modal) closeModal();
                        });
                        document.addEventListener('keydown', function (e) {
                          if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
                        });
                      });
                    })();
                  </script>
                </div>

              {% when 'variant_selector' %}
                <div class="variant">
                  <div class="variant-wrapper">
                    <div class="select_variant">
                      {% unless product.has_only_default_variant %}
                        <variant-selector data-url="{{ product.url }}" data-section="{{ section.id }}">
                          <div class="sv-perKg">
                            <p>{{ 'sections.product.select_variant' | t }}</p>
                            {% comment %} <div class="perKg">
                              {% if selected_variant.unit_price_measurement %}
                                {{ selected_variant.unit_price | money }} / {{ selected_variant.unit_price_measurement.reference_unit }}
                              {% comment %} {{ selected_variant.unit_price_measurement.reference_value }} {% endcomment %}
                              {% else %}
                                {{ selected_variant.price | money }} / unit
                              {% endif %}
                            </div> {% endcomment %}
                          </div>
                          {% for option in product.options_with_values %}
                            <div class="variant-option" data-option="{{ option.name }}">
                              <ul class="variant-values" data-index="{{ forloop.index0 }}">
                                {% for value in option.values %}
                                  {% assign matched_variant = nil %}

                                  {% for variant in product.variants %}
                                    {% case option.position %}
                                      {% when 1 %}
                                        {% if variant.option1 == value %}
                                          {% assign matched_variant = variant %}
                                          {% break %}
                                        {% endif %}
                                      {% when 2 %}
                                        {% if variant.option2 == value %}
                                          {% assign matched_variant = variant %}
                                          {% break %}
                                        {% endif %}
                                      {% when 3 %}
                                        {% if variant.option3 == value %}
                                          {% assign matched_variant = variant %}
                                          {% break %}
                                        {% endif %}
                                    {% endcase %}
                                  {% endfor %}

                                  <li
                                    class="variant-value {% if option.selected_value == value %}active{% endif %}{% unless matched_variant.available %} is-sold-out{% endunless %}"
                                    data-value="{{ value | escape }}"
                                    data-available="{{ matched_variant.available }}"
                                    {% if matched_variant.metafields.custom.bestseller == true %}
                                    data-best="bestseller"
                                    {% endif %}>
                                    {% if matched_variant.metafields.custom.bestseller == true %}
                                      <div class="vv-bestseller">{{ 'sections.product.best_seller' | t }}</div>
                                    {% endif %}
                                    <div class="vv-value">
                                      <div class="vvv-value">
                                        {{ value }}
                                      </div>
                                      <div class="perKg">
                                        {% comment %} {% if matched_variant.unit_price_measurement %}
                                          {{ matched_variant.unit_price | money }} / {{ matched_variant.unit_price_measurement.reference_unit }}
                                        {% comment %} {{ matched_variant.unit_price_measurement.reference_value }} {% endcomment %}
                                        {% else %}
                                          {{ matched_variant.price | money }} / unit
                                        {% endif %} {% endcomment %}
                                         {% if matched_variant.metafields.custom.pieces %}
                                            ( {{ matched_variant.metafields.custom.pieces }} )
                                          {% endif %}
                                      </div>
                                    </div>
                                    <div class="vv-peices">
                                        {% comment %} This gets the actual symbol ($, €, Rs.) directly from your store settings {% endcomment %}
                                        {% assign currency_suffix = cart.currency.symbol %}

                                        {% if matched_variant.unit_price_measurement %}
                                          {{ matched_variant.unit_price | money_without_currency }} {{ currency_suffix }} / {{ matched_variant.unit_price_measurement.reference_unit }}
                                        {% else %}
                                          {{ matched_variant.price | money_without_currency }} {{ currency_suffix }} / unit
                                        {% endif %}
                                      </div>
                                  </li>
                                {% endfor %}
                              </ul>
                            </div>
                          {% endfor %}

                          <script type="application/json">
                            [
                              {% for variant in product.variants %}
                                {
                                  "id": {{ variant.id | json }},
                                  "available": {{ variant.available | json }},
                                  "price": {{ variant.price | json }},
                                  "compare_at_price": {{ variant.compare_at_price | json }},
                                  "unit_price": {{ variant.unit_price | json }},
                                  "unit_price_reference_unit": {{ variant.unit_price_measurement.reference_unit | json }},
                                  "featured_media_id": {{ variant.featured_media.id | json }},
                                  "options": {{ variant.options | json }},
                                  "shipped_by": {{ variant.metafields.custom.shipped_by.value | default: variant.metafields.custom.shipped_by | default: product.metafields.custom.shipped_by.value | default: product.metafields.custom.shipped_by | json }}
                                }{% unless forloop.last %},{% endunless %}
                              {% endfor %}
                            ]
                          </script>
                        </variant-selector>
                      {% endunless %}
                    </div>
                    <div class="priceCheckout">
                      
                      <div class="submit submit--with-qty">
                        <div class="qty-selector">
                          <button type="button" class="qty-btn minus" data-action="decrease">−</button>
                          <input
                            type="number"
                            name="quantity"
                            id="Quantity"
                            value="1"
                            min="1"
                          >
                          <button type="button" class="qty-btn plus" data-action="increase">+</button>
                        </div>

                        <button
                          type="submit"
                          class="custom-btn filled"
                          id="add-to-cart"
                        >
                          <span class="btn-text">
                            <span class="btn-label">
                              {%- if selected_variant.available -%}
                                {{ 'products.product.add_to_cart' | t }}
                              {%- else -%}
                                {{ 'products.product.sold_out' | t }}
                              {%- endif -%}
                            </span>
                            <span class="btn-separator"> - </span><span class="btn-price">—</span>
                          </span>

                          <span class="btn-spinner" aria-hidden="true"></span>
                          <span class="btn-check" aria-hidden="true">✓</span>
                        </button>

                        
                      </div>

                    </div>
                    <p style='margin:0;' class="delivery-to">
                      <span class="product_delivery_modal_deliver_to">{{ 'sections.product.deliver_to' | t }}</span>
                      {{ localization.country }} {{ 'sections.product.delivery_by' | t }} :
                      <span class="calculated-delivery-date"></span>
                        <span class="product_delivery_modal_opener" data-popup-delivery-cost-title="Wie viel kostet die Lieferung und wie lange dauert sie?" data-popup-delivery-country="Liefern nach" data-popup-calculated-delivery-date="Bestelle heute für die Lieferung ab">
                          <small>{{ 'sections.product.details' | t }}</small>
                        </span>
                      {% comment %} <span id="delivery-data-new">9,90 €</span> {% endcomment %}
                    </p>
                    
                    {% comment %} <div class="payment-options">
                      <p>Guaranteed safe checkout with payment options</p>
                      <div class="po-icon-wrap">
                        {%- unless shop.enabled_payment_types == empty -%}
                          {%- for type in shop.enabled_payment_types -%}
                            {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                          {%- endfor -%}
                        {%- endunless -%}
                      </div>
                    </div> {% endcomment %}
                  </div>
                </div>

              {% when 'offer' %}
                {%- comment -%} Calculate indices for peeking at previous/next blocks {%- endcomment -%}
                {% assign prev_index = forloop.index0 | minus: 1 %}
                {% assign next_index = forloop.index0 | plus: 1 %}
                
                {%- comment -%} 
                  Only open the container if this is the FIRST offer in a consecutive row.
                {%- endcomment -%}
                {% if forloop.first or section.blocks[prev_index].type != 'offer' %}
                  <div class="product-offers">
                    <div class="offers-head">Offers</div>
                    <div class="offers-list">
                {% endif %}

                    <div class="offer-card" {{ block.shopify_attributes }}>
                      <div class="offer-left">
                        <span class="offer-icon">{% render 'icon-offer' %}</span>
                        <div>
                          <p class="offer-code">{{ block.settings.code }}</p>
                          <p class="offer-text">{{ block.settings.text }}</p>
                        </div>
                      </div>
                      <button type="button" class="offer-copy-btn" data-code="{{ block.settings.code }}">
                        {{ block.settings.code }}{% render 'icon-copy' %}
                      </button>
                    </div>

                {%- comment -%} 
                  Only close the container if the NEXT block is NOT an offer, or it's the last block.
                {%- endcomment -%}
                {% if forloop.last or section.blocks[next_index].type != 'offer' %}
                    </div>
                  </div>
                {% endif %}

              {% when '@app' %}
                <div class="app-block">{% render block %}</div>

            {% endcase %}
          {% endfor %}
        {% endform %}
      </div>
    </div>
  </div>
  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>
</div>

{% assign technical_details_data = product.metafields.custom.technical_details %}
{% assign description_data = product.metafields.custom.new_description %}
{% assign how_to_store_items = product.metafields.custom.how_to_store_eat.value %}
{% assign nutrition_details_data = product.metafields.custom.nutrition_details %}
{% assign nutrition_content_data = product.metafields.custom.nutrition_benefits_content %}
{% assign origin_sourcing_items = product.metafields.custom.origin_sourcing.value %}
{% assign taste_profile_data = product.metafields.custom.taste_profile.value %}
{% assign taste_profile_body = product.metafields.custom.taste_profile_body_text %}
{% assign country_season_data = product.metafields.custom.country_season.value %}
{% assign season_meta = country_season_data.season.value %}
{% assign product_shipped_by = product.metafields.custom.shipped_by.value | default: product.metafields.custom.shipped_by | downcase | strip %}
{% assign show_technical_details = false %}
{% if technical_details_data != blank %}
  {% assign show_technical_details = true %}
{% endif %}
{% assign show_description = false %}
{% if description_data != blank %}
  {% assign show_description = true %}
{% endif %}
{% assign show_how_to_store = false %}
{% if how_to_store_items != blank %}
  {% assign show_how_to_store = true %}
{% endif %}
{% assign show_nutrition = false %}
{% if nutrition_details_data != blank or nutrition_content_data != blank %}
  {% assign show_nutrition = true %}
{% endif %}
{% assign show_origin = false %}
{% if origin_sourcing_items != blank %}
  {% assign show_origin = true %}
{% endif %}
{% assign show_taste_profile = false %}
{% if taste_profile_data != blank or taste_profile_body != blank %}
  {% assign show_taste_profile = true %}
{% endif %}
{% assign show_seasonal = false %}
{% if season_meta != blank or product_shipped_by != blank %}
  {% assign show_seasonal = true %}
{% endif %}
{% assign show_product_accordion = false %}
{% if show_technical_details or show_description or show_how_to_store or show_nutrition or show_origin or show_taste_profile or show_seasonal %}
  {% assign show_product_accordion = true %}
{% endif %}

{% if show_product_accordion %}
<div class="product-accordion">
  <div class="container">
    <div class="pa-wrapper">

      {% comment %} How to Store and eat {% endcomment %}
       {% if show_how_to_store %}
      <div class="pa-item">
        <div class="pa-ques-wrap">
          <div class="pa-ques">
            {{ 'sections.product.how_to_eat_store' | t }}
          </div>
          <div class="pa-icon">
            {%- render 'product-accordian-icon' -%}
          </div>
        </div>
        <div class="pa-div">
          <div class="paeat-wrap">
            <div class="pa-eat-store">
              {% for item in product.metafields.custom.how_to_store_eat.value %}
                <div class="paes-item">
                  <div class="paes-icon square">
                    
                    {% if item.video.value != blank %}
                      {% comment %} 
                        If a video is uploaded, render the video player. 
                        The 'video_tag' filter handles the HTML5 video tag automatically.
                      {% endcomment %}
                      {{ item.video.value | video_tag: autoplay: true, loop: true, muted: true, controls: true }}
                    
                    {% elsif item.icon.value != blank %}
                      {% comment %} Fallback to the image icon if no video exists {% endcomment %}
                      <a
                        href="{{ item.icon | img_url: 'master' }}"
                        data-fancybox="how-to-store-gallery"
                        class="zoom-wrapper">
                        <img src="{{ item.icon | img_url: 'master' }}" alt="{{ item.field_title_optional }}">
                      </a>
                    {% endif %}

                  </div>

                  <div class="paes-content">
                    {% if item.field_title_optional != blank %}
                      <h3>{{ item.field_title_optional }}</h3>
                    {% endif %}
                    {{ item.body_text | metafield_tag }}
                  </div>
                </div>
              {% endfor %}
          </div>
          </div>
        </div>
      </div>
      {% endif %}

      {% comment %} Taste Profile {% endcomment %}
      {% if show_taste_profile %}
      <div class="pa-item">
        <div class="pa-ques-wrap">
          <div class="pa-ques">
            {{ 'sections.product.taste_profile' | t }}
          </div>
          <div class="pa-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none">
              <path
                d="M12 8V16"
                stroke="#202322"
                stroke-width="2"
                class="plus-horizontal"
                stroke-linejoin="round" />
              <path
                d="M8 12H16"
                stroke="#202322"
                stroke-width="2"
                class="plus-vertical"
                stroke-linejoin="round" />
            </svg>
          </div>
        </div>
        <div class="pa-div">
          <div class="padiv-para">
            <p>{{ taste_profile_body }}</p>
          </div>
          <div class="pad-taste-profile">
            {% comment %} Texture {% endcomment %}
            <div class="profile-in">
              <p class="tp-head texture">
                {{ 'sections.product.texture' | t }}
              </p>
              <div class="tp-wrap">
                {% assign texture_limit = taste_profile_data.texture %}
              <p class="tp-profile">
                  {{ 'sections.product.texture_low' | t }}
                </p>
                <div class="tp-pill-in texture">
                  {% for i in (1..5) %}
                    <div class="taste-pill {% if i <= texture_limit %}active{% endif %}"></div>
                  {% endfor %}
                </div>
                <p class="tp-profile">
                  {{ 'sections.product.texture_high' | t }}
                </p>
              </div>
            </div>
            {% comment %} Sweetness {% endcomment %}
            <div class="profile-in">
              <p class="tp-head sweetness">
                {{ 'sections.product.sweetness' | t }}
              </p>
              <div class="tp-wrap">
                {% assign sweetness_limit = taste_profile_data.sweetness %}
                <p class="tp-profile">{{ 'sections.product.sweetness_low' | t }}</p>
                <div class="tp-pill-in sweetness">
                  {% for i in (1..5) %}
                    <div class="taste-pill {% if i <= sweetness_limit %}active{% endif %}"></div>
                  {% endfor %}
                </div>
                <p class="tp-profile">{{ 'sections.product.sweetness_high' | t }}</p>
              </div>
            </div>
            {% comment %} Sourness {% endcomment %}
            <div class="profile-in">
              <p class="tp-head sourness">
                {{ 'sections.product.sourness' | t }}
              </p>
              <div class="tp-wrap">
                {% assign sourness_limit = taste_profile_data.sourness %}
                <p class="tp-profile">{{ 'sections.product.sourness_low' | t }}</p>
                <div class="tp-pill-in sourness">
                  {% for i in (1..5) %}
                    {% comment %} Changed sweetness_limit to sourness_limit below {% endcomment %}
                    <div class="taste-pill {% if i <= sourness_limit %}active{% endif %}"></div>
                  {% endfor %}
                </div>
                <p class="tp-profile">{{ 'sections.product.sourness_high' | t }}</p>
              </div>
            </div>
            {% comment %} Juiciness {% endcomment %}
            <div class="profile-in">
              <p class="tp-head juiciness">
                {{ 'sections.product.juiciness' | t }}
              </p>
              <div class="tp-wrap">
                {% assign juiciness_limit = taste_profile_data.juiciness %}
                <p class="tp-profile">{{ 'sections.product.juiciness_low' | t }}</p>
                <div class="tp-pill-in juiciness">
                  {% for i in (1..5) %}
                    <div class="taste-pill {% if i <= juiciness_limit %}active{% endif %}"></div>
                  {% endfor %}
                </div>
                <p class="tp-profile">{{ 'sections.product.juiciness_high' | t }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      {% endif %}

      {% comment %} Origin & Sourcing {% endcomment %}
       {% if show_origin %}
       <div class="pa-item">
          <div class="pa-ques-wrap">
              <div class="pa-ques">
                {{ 'sections.product.origin_sourcing' | t }}
              </div>
              <div class="pa-icon">
                {%- render 'product-accordian-icon' -%}
              </div>
          </div>
          <div class="pa-div">
            <div class="pa-eat-store">
              {% for item in origin_sourcing_items %}
                <div class="paes-item">
                  <div class="paes-icon square">
                      {% if item.origin_video.value != blank %}
                        {{ item.origin_video.value | video_tag: autoplay: true, loop: true, muted: true, controls: true }}
                      {% elsif item.origin_image != blank %}
                        <a
                          href="{{ item.origin_image | img_url: 'master' }}"
                          data-fancybox="origin-sourcing-gallery"
                          class="zoom-wrapper">
                          <img src="{{ item.origin_image | img_url: 'master' }}" alt="{{ item.origin_label }}">
                        </a>
                      {% endif %}
                  </div>
                  <div class="paes-content">
                    {% if item.origin_label != blank %}
                      <h3>{{ item.origin_label }}</h3>
                    {% endif %}
                    {{ item.origin_content | metafield_tag }}
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
       </div>
       {% endif %}

       {% comment %} Nutrition & Benefits {% endcomment %}
       {% if show_nutrition %}
      <div class="pa-item">
        <div class="pa-ques-wrap">
          <div class="pa-ques">
            {{ 'sections.product.nutrition_benefits' | t }}
          </div>
          <div class="pa-icon">
            {%- render 'product-accordian-icon' -%}
          </div>
        </div>
        <div class="pa-div">
          <div class="nutrition-info">
            <div class="nutri-image">
                {% comment %} <img src="{{ product.metafields.custom.nutrition_benefits_image |  img_url: 'master' }}" alt=""> {% endcomment %}
                 {{ product.metafields.custom.nutrition_details | metafield_tag }}
            </div>
            <div class="nutri-info">
              {{ product.metafields.custom.nutrition_benefits_content | metafield_tag }}
            </div>
          </div>
        </div>
      </div>
      {% endif %}

      {% comment %} Description {% endcomment %}
       {% if show_description %}
       <div class="pa-item">
          <div class="pa-ques-wrap">
              <div class="pa-ques">
                {{ 'sections.product.description' | t }}
              </div>
              <div class="pa-icon">
                {%- render 'product-accordian-icon' -%}
              </div>
          </div>
          <div class="pa-div">
            {% comment %} <p class="product-description-metafield">{{ product.metafields.custom.description }}</p> {% endcomment %}
            <div class="product-desc">
              {{ product.metafields.custom.new_description | metafield_tag }}
            </div>
          </div>
       </div>
       {% endif %}

      {% comment %} Seasonal Information {% endcomment %}
      {% if show_seasonal %}
      <div class="pa-item">
        <div class="pa-ques-wrap">
          <div class="pa-ques">
            {{ 'sections.product.seasonal_calendar_sourcing' | t }}
          </div>
          <div class="pa-icon">
            {%- render 'product-accordian-icon' -%}
          </div>
        </div>
        <div class="pa-div">
          <div class="pa-seasons">
            {%- assign months_en = "January,February,March,April,May,June,July,August,September,October,November,December" | split: ',' -%}
            {%- assign months_de = "Januar,Februar,März,April,Mai,Juni,Juli,August,September,Oktober,November,Dezember" | split: ',' -%}
            {%- assign months_fr = "Janvier,Février,Mars,Avril,Mai,Juin,Juillet,Août,Septembre,Octobre,Novembre,Décembre" | split: ',' -%}

            {%- assign high_raw = season_meta.high_season_month.value | default: '' | split: ',' -%}
            {%- assign low_raw = season_meta.low_season_month.value | default: '' | split: ',' -%}

            {%- assign high_indexes = '' -%}
            {% for h in high_raw %}
              {% assign h_clean = h | strip %}

              {% for m in months_en %}
                {% assign m_index = forloop.index %}

                {% if m == h_clean %}
                  {% assign high_indexes = high_indexes | append: m_index | append: ',' %}
                {% endif %}
              {% endfor %}

            {% endfor %}

            {%- assign low_indexes = '' -%}
            {% for l in low_raw %}
              {% assign l_clean = l | strip %}

              {% for m in months_en %}
                {% assign m_index = forloop.index %}

                {% if m == l_clean %}
                  {% assign low_indexes = low_indexes | append: m_index | append: ',' %}
                {% endif %}
              {% endfor %}

            {% endfor %}

            <div class="pas-month">
              {%- for month in months_en -%}

                {%- assign index0 = forloop.index0 -%}
                {%- assign index = forloop.index -%}

                {%- case request.locale.iso_code -%}
                  {%- when 'de' -%}
                    {%- assign display_month = months_de[index0] -%}
                  {%- when 'fr' -%}
                    {%- assign display_month = months_fr[index0] -%}
                  {%- else -%}
                    {%- assign display_month = months_en[index0] -%}
                {%- endcase -%}

                {%- assign index_key = index | append: ',' -%}

            {%- assign is_high = false -%}
            {%- if high_indexes contains index_key -%}
              {%- assign is_high = true -%}
            {%- endif -%}

            {%- assign is_low = false -%}
            {%- if low_indexes contains index_key -%}
              {%- assign is_low = true -%}
            {%- endif -%}

                <div class="month-in{% if is_high %} high-season{% elsif is_low %} low-season{% endif %}">
                  <p>{{ display_month | slice: 0, 3 }}</p>
                  <div class="month-pill"></div>
                </div>

              {%- endfor -%}
            </div>
            <div class="pas-country">
              <p>{{ product.metafields.custom.country_of_origin.value.country_name }}</p>
              {% assign shipped_by = selected_variant.metafields.custom.shipped_by.value | default: selected_variant.metafields.custom.shipped_by | default: product.metafields.custom.shipped_by.value | default: product.metafields.custom.shipped_by | downcase | strip %}
              {% assign shipped_by_key = shipped_by %}
              {% if shipped_by == 'luft' or shipped_by == 'air' %}
                {% assign shipped_by_key = 'air' %}
              {% elsif shipped_by == 'see' or shipped_by == 'sea' %}
                {% assign shipped_by_key = 'sea' %}
              {% elsif shipped_by == 'straße' or shipped_by == 'strasse' or shipped_by == 'road' %}
                {% assign shipped_by_key = 'road' %}
              {% endif %}
              <div
                class="pas-shipping"
                data-product-shipping
                data-shipping-value="{{ shipped_by_key }}"
                data-shipping-label="{{ shipped_by }}">
                <span class="pas-shipping-icon" data-shipping-icon>
                  {% if shipped_by_key == 'air' %}
                    {% render 'air' %}
                  {% elsif shipped_by_key == 'sea' %}
                    {% render 'sea' %}
                  {% elsif shipped_by_key == 'road' %}
                    {% render 'road' %}
                  {% endif %}
                </span>
                <span class="pas-shipping-text" data-shipping-text>
                  {% if shipped_by != blank %}
                    Shipped by {{ shipped_by }}
                  {% endif %}
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
      {% endif %}

      {% comment %} Technical Details {% endcomment %}
       {% if show_technical_details %}
       <div class="pa-item">
          <div class="pa-ques-wrap">
              <div class="pa-ques">
                {{ 'sections.product.technical_details' | t }}
              </div>
              <div class="pa-icon">
                {%- render 'product-accordian-icon' -%}
              </div>
          </div>
          <div class="pa-div">
              <div class="product-desc">
                {% comment %} {{ product.metafields.custom.technical_details | metafield_tag }} {% endcomment %}
                 <div class="tech-list">
                    {%- if product.metafields.custom.alternative_name != blank -%}
                      <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.scientific_name' | t }}:</div>
                        <div class="ti-data">{{ product.metafields.custom.alternative_name }}</div>
                      </div>
                    {%- endif -%}
                    
                    {%- if product.metafields.custom.country_of_origin.value != blank -%}
                      <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.origin' | t }}:</div>
                        <div class="ti-data">{{ product.metafields.custom.country_of_origin.value.country_name }}</div>
                      </div>
                    {%- endif -%}
                    
                    {%- if product.metafields.custom.weight_per_piece != blank -%}
                    <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.weight_per_piece' | t }}:</div>
                        <div class="ti-data">{{ product.metafields.custom.weight_per_piece }}</div>
                    </div>
                    {%- endif -%}

                    {%- if product.metafields.custom.ingredients.value != blank -%}
                    <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.ingredients' | t }}:</div>
                        <div class="ti-data">{{ product.metafields.custom.ingredients.value | newline_to_br }}</div>
                    </div>
                    {%- endif -%}

                    {%- assign manufacturing_text = '' -%}
                    {%- assign manufacturing_metafield = product.metafields.custom.manufacturing -%}
                    {%- if manufacturing_metafield != blank and manufacturing_metafield.value != blank -%}
                      {%- if manufacturing_metafield.type contains 'list.' -%}
                        {%- assign manufacturing_text = manufacturing_metafield.value | join: ', ' -%}
                      {%- else -%}
                        {%- assign manufacturing_text = manufacturing_metafield.value -%}
                      {%- endif -%}
                    {%- endif -%}

                    {%- if manufacturing_text != blank -%}
                    <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.manufacturing' | t }}:</div>
                        <div class="ti-data">{{ manufacturing_text }}</div>
                    </div>
                    {%- endif -%}

                    {%- assign allergens_text = '' -%}
                    {%- assign allergens_metafield = product.metafields.shopify.allergen_information -%}
                    {%- if allergens_metafield == blank -%}
                      {%- assign allergens_metafield = product.metafields.shopify.allergens -%}
                    {%- endif -%}
                    {%- if allergens_metafield == blank -%}
                      {%- assign allergens_metafield = product.metafields.standard.allergen_information -%}
                    {%- endif -%}
                    {%- if allergens_metafield == blank -%}
                      {%- assign allergens_metafield = product.metafields.standard.allergens -%}
                    {%- endif -%}
                    {%- if allergens_metafield != blank and allergens_metafield.value != blank -%}
                      {%- if allergens_metafield.type contains 'list.' -%}
                        {%- assign allergens_text = allergens_metafield.value | join: ', ' -%}
                      {%- else -%}
                        {%- assign allergens_text = allergens_metafield.value -%}
                      {%- endif -%}
                    {%- endif -%}

                    {%- if allergens_text != blank -%}
                    <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.allergens' | t }}:</div>
                        <div class="ti-data">{{ allergens_text }}</div>
                    </div>
                    {%- endif -%}

                    {%- if product.metafields.custom.cross_contamination.value != blank -%}
                    <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.cross_contamination' | t }}:</div>
                        <div class="ti-data">{{ product.metafields.custom.cross_contamination.value | newline_to_br }}</div>
                    </div>
                    {%- endif -%}

                    {%- if product.metafields.custom.best_before_date.value != blank -%}
                    <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.best_before_date' | t }}:</div>
                        <div class="ti-data">{{ product.metafields.custom.best_before_date.value | date: "%d.%m.%Y" }}</div>
                    </div>
                    {%- endif -%}

                    {%- if product.metafields.custom.net_quantity.value != blank -%}
                    <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.net_quantity' | t }}:</div>
                        <div class="ti-data">{{ product.metafields.custom.net_quantity.value }}</div>
                    </div>
                    {%- endif -%}

                    {%- if product.metafields.custom.storage_conditions.value != blank -%}
                    <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.storage_conditions' | t }}:</div>
                        <div class="ti-data">{{ product.metafields.custom.storage_conditions.value | newline_to_br }}</div>
                    </div>
                    {%- endif -%}

                    {%- if product.metafields.custom.quality_label != blank -%}
                    <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.quality_label' | t }}:</div>
                        <div class="ti-data">{{ product.metafields.custom.quality_label }}</div>
                    </div>
                    {%- endif -%}

                    {%- assign certificate_names = '' -%}
                    {%- if product.metafields.custom.certificate.value != blank -%}
                      {%- for item in product.metafields.custom.certificate.value -%}
                        {%- if item.display_name != blank -%}
                          {%- if certificate_names != blank -%}
                            {%- assign certificate_names = certificate_names | append: ', ' -%}
                          {%- endif -%}
                          {%- assign certificate_names = certificate_names | append: item.display_name -%}
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}

                    {%- if certificate_names != blank -%}
                    <div class="tech-item">
                        <div class="ti-name">{{ 'sections.product.certificate' | t }}:</div>
                        <div class="ti-data">{{ certificate_names }}</div>
                    </div>
                    {%- endif -%}

                 </div>
              </div>
          </div>
       </div>
       {% endif %}
    </div>
  </div>
</div>
{% endif %}

{% assign deliveryBlock = section.blocks | where: 'type', 'delivery-info' | first %}
  <div class="product_delivery_modal_container modal fade">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="delivery-cost-title">How much does delivery cost and how long does it take?</h5>
          <button
            type="button"
            class="close"
            data-dismiss="modal"
            aria-label="Close">
            <svg
              width="15px"
              height="15px"
              fill="none"
