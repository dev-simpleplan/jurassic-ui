<section class="home-banner">
  <div class="banner-bg">
    <picture>
      {% if section.settings.banner_bg_mobile != blank %}
        <source media="(max-width: 767px)" srcset="{{ section.settings.banner_bg_mobile | img_url: 'master' }}">
      {% endif %}
      <img src="{{ section.settings['banner-bg'] | img_url: 'master' }}" alt="Banner Image" class="img">
    </picture>
  </div>

  <div class="banner-in">
    <div class="container">
      <div class="banner-content">
        <div class="bc-top">
          <div class="bct-heading">
            <div class="heading-star">
                {% render 'rating-stars-fa', rating: section.settings.review_star_star %}
                <div class="rating-text" aria-hidden="true">{{ section.settings.review_star_rating }}</div>
            </div>
            <h1 data-aos="fade-up" data-aos-duration="1000">{{ section.settings.head }}</h1>
            <p data-aos="fade-up" data-aos-duration="1000" data-aos-delay="50">{{ section.settings.para }}</p>
            <div class="bcth-button" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="100">
              <a href="{{ section.settings.button_link | default: '#' }}" class="custom-btn filled">{{ section.settings.button_text }}</a>
            </div>
          </div>
        </div>

        <div class="bc-bottom">
          <div class="bcb-reviews-wrap">
            {% for block in section.blocks %}
              <div class="bcbr-item" {{ block.shopify_attributes }}>
                <div class="bcbri-top">{{ block.settings.review-top }}</div>
                <div class="bcbri-bottom">
                  {% render 'rating-stars-fa', rating: block.settings.review_star %}
                  <div class="rating-text" aria-hidden="true">{{ block.settings.review_star }}</div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home Banner",
  "class": "homepage-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner-bg",
      "label": "Banner Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "banner_bg_mobile",
      "label": "Banner Image (Mobile)"
    },
    {
      "type": "text",
      "id": "review_star_rating",
      "label": "Review Text",
      "default": "150,000 satisfied customers"
    },
    {
      "type": "range",
      "id": "review_star_star",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "label": "Star Ratings",
      "default": 5
    },
    {
      "type": "text",
      "id": "head",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "para",
      "label": "Paragraph"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "name": "Reviews",
      "type": "reviews",
      "settings": [
        {
          "type": "text",
          "id": "review-top",
          "label": "Platform Name",
          "default": "Google Reviews"
        },
        {
          "type": "range",
          "id": "review_star",
          "min": 0,
          "max": 5,
          "step": 0.1,
          "label": "Star Ratings",
          "default": 4.7
        }
      ]
    }
  ],
  "presets": [
    { "name": "Home Banner" }
  ]
}
{% endschema %}
