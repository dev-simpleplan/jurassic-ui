<script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>

<section class="imagescroll">
    <div class="container-fluid">
        <div class="imgcroll-in" id="trigger1">
            <div class="sec-heading small">
                <div class="heading center">
                    <h2>{{ section.settings.heading }}</h2>
                    <p>{{ section.settings.subheading }}</p>
                </div>
            </div>
            <div id="stackingGallery">
                <div class="scrollimg-wrap">
                    <div class="gallery__grid">
                        {% for block in section.blocks %}
                            <div class="scroll-image index-{{ forloop.index }}" id="pin1">
                                <img class="icon collection-img" src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.image.alt }}" />
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    gsap.registerPlugin(ScrollTrigger);

    // Force scroll to top on reload
    window.onbeforeunload = function() {
        window.scrollTo(0, 0);
    };

    // Use window.onload to ensure images are fully rendered before GSAP math starts
    window.addEventListener("load", () => {
        let mm = gsap.matchMedia();

        mm.add("(min-width: 768px)", () => {
            const cards = gsap.utils.toArray('.scroll-image');
            const wrapper = document.querySelector(".imagescroll");
            
            if (!wrapper || cards.length === 0) return;

            // Initial state set
            gsap.set('.index-1', { yPercent: 20, rotate: -5 });
            gsap.set('.index-2', { yPercent: 60, rotate: 8 });
            gsap.set('.index-3', { yPercent: 40, rotate: -5 });

            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: wrapper,
                    start: 'top top',
                    end: '+=100%', 
                    scrub: 0.5, 
                    pin: true,
                    pinSpacing: true,
                    invalidateOnRefresh: true, // Re-calculates if window is resized
                    anticipatePin: 1, // Prevents slight jump when pinning starts
                }
            });

            cards.forEach((card) => {
                tl.to(card, {
                    yPercent: 0,
                    rotate: 0,
                    ease: 'none', 
                }, 0);
            });

            tl.from('.gallery__grid', { yPercent: 6, ease: 'none' }, 0);
        });

        // Final safety refresh
        ScrollTrigger.refresh();
    });
</script>

{% schema %}
  {
    "name": "imagesscroll",
    "tag": "section",
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "Section heading",
            "default": "The Crew Behind Your Journey to Wild Taste"
        },
        {
            "type": "text",
            "id": "subheading",
            "label": "Section subheading",
            "default": "We’re the hands and hearts behind the flavor — driven by purpose, powered by fruit. Everyone leads, everyone cares. We move fast, laugh loud, and never lose sight of what matters."
        }
    ],
    "blocks": [
        {
            "type": "slide",
            "name": "slide",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Select Image"
                }   
            ]
        }
    ],
    "presets": [
      {
        "name": "imagesscroll",
        "settings": {
        }
      }
    ]
  }
{% endschema %}