            "label": "Announcement Prefix",
            "default": "Free shipping on orders above"
        },
        {
            "type": "number",
            "id": "tbtext_amount",
            "label": "Free Shipping Threshold",
            "default": 450
        }

    ],
    "blocks": [
        {
            "type": "market_threshold",
            "name": "Market Threshold",
            "settings": [
                {
                    "type": "text",
                    "id": "market_code",
                    "label": "Country / Market Code",
                    "info": "Use country codes like DE, IN, US, FR, GB"
                },
                {
                    "type": "number",
                    "id": "amount",
                    "label": "Threshold Amount"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "top-bar",
            "settings": {
            }
        }
    ]
  }
