{% if collection.handle != 'all' %}
  {% comment %} <div class="collection-banner">
    <div class="container">
      <div class="cb-wrapper">
        <div class="heading center">
          <h1>{{ section.settings.head }}</h1>
        </div>
        <div class="cb-collection">
          {% for block in section.blocks %}
            {% assign collection_item = block.settings.col %}
            <a href="{{ collection_item.url }}" class="cbcIn">
              <div class="cbcImg">
                {% if collection_item.featured_image %}
                  <img src="{{ collection_item.featured_image | img_url: 'master' }}" alt="{{ collection_item.title }}">
                {% elsif block.settings.col_img %}
                  <img src="{{ block.settings.col_img | img_url: 'master' }}" alt="{{ collection_item.title }}">
                {% endif %}
              </div>

              <div class="cbcTxt">
                {% assign collection_title = block.settings.col_name %}
                {% if collection_title == '' %}
                  <p>{{ collection_item.title | strip_html | strip }}</p>
                {% else %}
                  <p>{{ block.settings.col_name }}</p>
                {% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </div> {% endcomment %}
{% endif %}
<div class="collection-banner">
  <div class="collection-main">
    <div class="container">
      <div class="cb-wrapper">
        <div class="breadcrumbs">
            <a href="{{ routes.root_url }}">Home</a>
            <p>
              >
            </p>
            <p>
              {% if collection.handle == 'all' %}
                All {{ collection.title }}
              {% else %}
                {{ collection.title }}
              {% endif %}
            </p>
          </div>
        {% comment %} <div class="heading">
          <h1>{{ section.settings.head }}</h1>
        </div> {% endcomment %}
        <div class="head">
          
          {% if collection.handle == 'all' %}
            <h1>All {{ collection.title }}</h1>
          {% else %}
            <h1>{{ collection.title }}</h1>
          {% endif %}
        </div> 
        {%- liquid 
  # 1. Define where the section IS allowed to show
  assign allowed_collections = "all-fruits,new,all-products" | split: ","
-%}

{%- if allowed_collections contains collection.handle -%}
  <div class="cb-collection">
    {% for block in section.blocks %}
      {% assign collection_item = block.settings.col %}
      
      {%- comment -%} 
        2. SKIP the block if it matches the current collection handle
      {%- endcomment -%}
      {% if collection_item.handle == collection.handle %}
        {% continue %}
      {% endif %}

      <a href="{{ collection_item.url }}" class="cbcIn">
        <div class="cbcImg">
          {% if collection_item.featured_image %}
            <img src="{{ collection_item.featured_image | img_url: 'master' }}" alt="{{ collection_item.title }}">
          {% elsif block.settings.col_img %}
            <img src="{{ block.settings.col_img | img_url: 'master' }}" alt="{{ collection_item.title }}">
          {% endif %}
        </div>

        <div class="cbcTxt">
          {% assign collection_title = block.settings.col_name %}
          {% if collection_title == blank %}
            <p>{{ collection_item.title | strip_html | strip }}</p>
          {% else %}
            <p>{{ block.settings.col_name }}</p>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>
{%- endif -%}
      </div>
      <div class="cm-wrapper">
        {% comment %} <div class="head">
          
          {% if collection.handle == 'all' %}
            <h1>All {{ collection.title }}</h1>
          {% else %}
            <h2>{{ collection.title }}</h2>
          {% endif %}
        </div> {% endcomment %}
        <div class="tc-filter-wrap">
          <div class="filter-wrap filter">
            <div class="filter-buttton">
              Filter {% render 'filter-icon' %}
            </div>
            <div class="filter-sidebar">
              <div class="filtersidebar-in" data-lenis-prevent>
                <div class="filter-cross-div">
                  <p><span>Filter</span> {% render 'filter-icon' %}</p>
                  <div class="filter-close-mob">{% render 'cross' %}</div>
                </div>
                <div class="filter-sidebar-form">
                  <form>
                    <div class="form-filter-wrap list">
                      <div class="ff-head">
                        <p>Sort By</p>
                        <div class="filter-down-arrow">{% render "icon-arrow_down" %}</div>
                      </div>
                      <div class="ff-in">
                        <ul>
                          {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
                          {% for option in collection.sort_options %}
                            <li>
                              <label for="sort-{{ forloop.index }}">
                                <input type="radio" name="sort_by" value="{{ option.value }}" id="sort-{{ forloop.index }}" {% if option.value == sort_by %}checked{% endif %}>
                                {{ option.name }}
                              </label>
                            </li>
                          {% endfor %}
                        </ul>
                      </div>
                    </div>

                    {%- for filter in collection.filters -%}
                      <div class="form-filter-wrap {{ filter.type }}">
                        <div class="ff-head">
                          <p>{{ filter.label }}</p>
                          <div class="filter-down-arrow">{% render "icon-arrow_down" %}</div>
                        </div>
                        <div class="ff-in">
                          {%- case filter.type -%}
                            {%- when 'boolean' -%}
                              <ul>
                                <li>
                                  <label for="Filter-{{ filter.param_name }}-true">
                                    <input type="radio" name="{{ filter.param_name }}" value="{{ filter.true_value.value }}" id="Filter-{{ filter.param_name }}-true" {% if filter.true_value.active %}checked{% endif %} {% if filter.true_value.count == 0 and filter.true_value.active == false %}disabled{% endif %}>
                                    {{ filter.true_value.label }}
                                  </label>
                                </li>
                                <li>
                                  <label for="Filter-{{ filter.param_name }}-false">
                                    <input type="radio" name="{{ filter.param_name }}" value="{{ filter.false_value.value }}" id="Filter-{{ filter.param_name }}-false" {% if filter.false_value.active %}checked{% endif %} {% if filter.false_value.count == 0 and filter.false_value.active == false %}disabled{% endif %}>
                                    {{ filter.false_value.label }}
                                  </label>
                                </li>
                              </ul>
                            {%- when 'list' -%}
                              <ul>
                                {%- for filter_value in filter.values -%}
                                  <li>
                                    <label for="Filter-{{ filter.param_name }}-{{ forloop.index }}">
                                      <input type="checkbox" name="{{ filter_value.param_name }}" value="{{ filter_value.value }}" id="Filter-{{ filter.param_name }}-{{ forloop.index }}" {% if filter_value.active %}checked{% endif %} {% if filter_value.count == 0 and filter_value.active == false %}disabled{% endif %}>
                                      {{ filter_value.label }} ({{ filter_value.count }})
                                    </label>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- when 'price_range' -%}
                              {%- endcase -%}
                        </div>
                      </div>
                    {%- endfor -%}
                    <div class="clear-filter">
                      <a href="{{ collection.url }}" class="reset-btn">Reset</a>
                      <button type="submit" class="apply-filter-btn custom-btn black">Apply Filters</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>

          {% comment %} Self Populating Filters with condition {% endcomment %}
          {% comment %} <div class="quick-filters">
            <div class="qf-wrapper">
              {%- assign availability_filter = collection.filters | where: "param_name", "filter.v.availability" | first -%}
              {%- if availability_filter -%}
                {%- for filter_value in availability_filter.values -%}
                  {%- if filter_value.count > 0 or filter_value.active -%}
                    <button type="button" class="qf-pill {% if filter_value.active %}is-active{% endif %}" data-name="{{ filter_value.param_name }}" data-value="{{ filter_value.value }}">
                      {{ filter_value.label }} ({{ filter_value.count }})
                    </button>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
              <button type="button" class="qf-pill clear-all-pill" style="display: none;">Clear All ✕</button>
            </div>
          </div> {% endcomment %}

          {% comment %} Manual Filter with condition {% endcomment %}
           <div class="quick-filters">
              <div class="qf-wrapper">
                  {%- comment -%} 1. Availability (Hardcoded - Always Visible) {%- endcomment -%}
                  <button type="button" class="qf-pill" data-name="filter.v.availability" data-value="1">In Stock</button>
                  <button type="button" class="qf-pill" data-name="filter.v.availability" data-value="0">Out Of Stock</button>

                  {%- comment -%} 2. Country of Origin (Dynamic Curated List) {%- endcomment -%}
                  {%- assign origin_filter = collection.filters | where: "param_name", "filter.p.m.custom.country_of_origin" | first -%}
                  
                  {%- if origin_filter -%}
                    {%- for value in origin_filter.values -%}
                      {%- comment -%} 
                        Check if the current filter value is "Spain". 
                        This is safer because it iterates through actual available values.
                      {%- endcomment -%}
                      {%- if value.label contains "Spain" -%}
                        {%- if value.count > 0 or value.active -%}
                          <button type="button" class="qf-pill" 
                                  data-name="{{ value.param_name }}" 
                                  data-value="{{ value.value }}">
                            Spain {% if value.count > 0 %}({{ value.count }}){% endif %}
                          </button>
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}

                  {%- comment -%} 3. Category (Mangoes) {%- endcomment -%}
                  {%- assign cat_filter = collection.filters | where: "label", "Category" | first -%}
                  {%- if cat_filter -%}
                    {%- for value in cat_filter.values -%}
                      {%- if value.label contains "Mango" -%}
                        {%- if value.count > 0 or value.active -%}
                          <button type="button" class="qf-pill" 
                                  data-name="{{ value.param_name }}" 
                                  data-value="{{ value.value }}">
                            Mangoes
                          </button>
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}

                  <button type="button" class="qf-pill clear-all-pill" style="display: none;">
                    Clear All ✕
                  </button>
                </div>
            </div>
        </div>
        <div class="collection-wrapper" id="ProductGrid">
          <div class="cart-loader">
            <div class="loader-spinner"></div>
          </div>
          {% paginate collection.products by section.settings.number_of_product %}
            {% if collection.products_count > 0 %}
              {% for product in collection.products %}
                {% render 'product-card-primary' | product: product %}
              {% endfor %}
              {% render 'pagination' | pagination: paginate %}
            {% else %}
              <div class="no-products-found">
                <h3>No products found</h3>
                <p>Try adjusting your filters or clearing them to see more delicious fruits.</p>
                <button type="button" class="reset-link custom-btn black" onclick="window.location.href=window.location.pathname">Clear all filters</button>
              </div>
            {% endif %}
          {% endpaginate %}
        </div>
      </div>
    </div>
  </div>
</div>

<section class="collection-seo-footer">
  <div class="container">
    <div class="seo-sec-wrapper">
      <div class="seo-content" id="seoContent">
        {{ collection.metafields.custom.seo_focused_paragraph | metafield_tag }}
      </div>
      <button type="button" class="seo-show-more" id="seoToggleButton">Show More</button>
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  
    // Selectors
    const filterForm = document.querySelector(".tc-filter-wrap form");
    const productGrid = document.querySelector("#ProductGrid");
    const filter_sidebar = document.querySelector('.filter-sidebar');
    const filter_button = document.querySelector('.filter-buttton');
    const filter_close = document.querySelector('.filter-close-mob');
    const clearAllBtn = document.querySelector('.clear-all-pill');
    const loader = productGrid.querySelector('.cart-loader');

    if (!filterForm || !productGrid) return;

    // --- 1. AJAX UTILITIES ---
    function updateProductGrid(extraParams = {}, urlOverride = null) {

        if (!productGrid) return;
        // 1. START LOADING
        if (loader) loader.classList.add('active');
        productGrid.style.pointerEvents = 'none'; // Prevent double-clicks while loading

        const formData = new FormData(filterForm);
        const searchParams = new URLSearchParams(formData);

        Object.keys(extraParams).forEach((key) => {
            searchParams.set(key, extraParams[key]);
        });

        // --- Add NoIndex logic ---
        // Check if any filters are active (excluding the sort_by parameter)
        let hasFilters = false;
        searchParams.forEach((value, key) => {
            if (key.includes('filter.') || key === 'constraint') {
                hasFilters = true;
            }
        });

        // If filters are active, append the noindex view
        if (hasFilters) {
            searchParams.set('view', 'noindex');
        } else {
            searchParams.delete('view');
        }

        let url = urlOverride ? urlOverride : `${window.location.pathname}?${searchParams.toString()}`;

        fetch(url)
            .then(res => res.text())
            .then(data => {
                const parser = new DOMParser();
                const newDoc = parser.parseFromString(data, "text/html");
                const newGrid = newDoc.querySelector("#ProductGrid");
                const newQuickFilters = newDoc.querySelector(".quick-filters");

                if (newGrid) {
                    productGrid.innerHTML = newGrid.innerHTML;
                }
                
                if (newQuickFilters) {
                    // This replaces the whole quick-filters div, 
                    // updating the 'is-disabled' class automatically
                    const oldFilters = document.querySelector(".quick-filters");
                    oldFilters.className = newQuickFilters.className; 
                    oldFilters.innerHTML = newQuickFilters.innerHTML;
                }

                // Re-run UI syncs
                if (typeof lenis !== 'undefined') lenis.resize();

                window.history.pushState({}, "", url);
                bindPaginationLinks();
                
                // Re-bind click events to new pills injected via AJAX
                bindQuickPills();
                toggleClearAllVisibility();

                // Re-enable pointer events.
                productGrid.style.pointerEvents = 'all';

                // Scroll to top of grid
                const topPos = productGrid.getBoundingClientRect().top + window.pageYOffset - 100;
                window.scrollTo({ top: topPos, behavior: "smooth" });
            })
            .catch(err => {
                if (loader) loader.classList.remove('active');
                productGrid.style.pointerEvents = 'all';
                console.error("Filter error:", err);
            });
    }

    function toggleClearAllVisibility() {
        const clearAllBtn = document.querySelector('.clear-all-pill');
        const filterForm = document.querySelector(".tc-filter-wrap form");
        if (!clearAllBtn || !filterForm) return;

        // 1. Check for checked inputs (excluding sort_by)
        const hasActiveInputs = Array.from(filterForm.querySelectorAll('input:checked'))
            .some(input => input.name !== 'sort_by');

        // 2. Check for pills that have the 'is-active' class
        const hasActivePills = document.querySelectorAll('.qf-pill.is-active').length > 0;

        // 3. Check the URL for filter parameters (as a fallback)
        const hasUrlFilters = window.location.search.includes('filter.');

        if (hasActiveInputs || hasActivePills || hasUrlFilters) {
            clearAllBtn.style.display = 'inline-block';
        } else {
            clearAllBtn.style.display = 'none';
        }
    }

    function bindQuickPills() {
        const pills = document.querySelectorAll('.qf-pill:not(.clear-all-pill)');
        const form = document.querySelector(".tc-filter-wrap form");

        function syncPillStates() {
            pills.forEach(pill => {
                const name = pill.getAttribute('data-name');
                const value = pill.getAttribute('data-value');
                const input = form.querySelector(`input[name="${name}"][value="${value}"]`);
                
                if (input) {
                    // Toggle Active State
                    pill.classList.toggle('is-active', input.checked);
                    
                    // Toggle Disabled State (matches your sidebar screenshot)
                    if (input.disabled) {
                        pill.classList.add('is-disabled');
                        pill.style.pointerEvents = 'none'; // Stop further clicks
                    } else {
                        pill.classList.remove('is-disabled');
                        pill.style.pointerEvents = 'all';
                    }
                }
            });
        }

        pills.forEach(button => {
            button.onclick = function() {
                const name = this.getAttribute('data-name');
                const value = this.getAttribute('data-value');
                const input = form.querySelector(`input[name="${name}"][value="${value}"]`);

                if (input && !input.disabled) {
                    input.checked = !input.checked;
                    updateProductGrid();
                }
            };
        });

        const clearBtn = document.querySelector('.clear-all-pill');
              if (clearBtn) {
                  clearBtn.onclick = (e) => {
                      e.preventDefault();
                      // Redirect to the clean collection URL to strip all filters
                      window.location.href = window.location.pathname;
                  };
              }

        syncPillStates();
    }

    function bindPaginationLinks() {
      document.querySelectorAll(".pagination a").forEach(link => {
          link.onclick = (e) => {
              e.preventDefault();
              let url = link.getAttribute("href");
              
              // If the URL doesn't have view=noindex but we are on page 2+, 
              // the theme.liquid logic will handle it, but adding it to the URL is cleaner.
              if (!url.includes('view=noindex')) {
                  url += (url.includes('?') ? '&' : '?') + 'view=noindex';
              }
              
              updateProductGrid({}, url);
          };
      });
  }

    // --- 2. SIDEBAR TOGGLE & OUTSIDE CLICK ---
    filter_button.onclick = (e) => {
        e.stopPropagation();
        filter_sidebar.classList.add('active');
        if (typeof lenis !== 'undefined') lenis.stop();
    };

    filter_close.onclick = () => closeSidebar();

    filter_sidebar.onclick = (e) => {
        if (e.target === filter_sidebar) closeSidebar();
    };

    function closeSidebar() {
        filter_sidebar.classList.remove('active');
        if (typeof lenis !== 'undefined') lenis.start();
    }

    // --- 3. ACCORDION (Bulletproof Version) ---
    document.querySelectorAll(".form-filter-wrap .ff-head").forEach(head => {
        head.addEventListener('click', function(e) {
            // Kill all other scripts trying to touch this click
            e.preventDefault();
            e.stopPropagation(); 
            e.stopImmediatePropagation(); 

            const body = this.nextElementSibling;
            const isActive = this.classList.contains("active");
            
            // 1. Close ALL other headers and bodies
            document.querySelectorAll(".ff-head").forEach(otherHead => {
                if (otherHead !== this) {
                    otherHead.classList.remove("active");
                    if (otherHead.nextElementSibling) {
                        otherHead.nextElementSibling.style.display = "none";
                    }
                }
            });

            // 2. Toggle the current one
            if (isActive) {
                this.classList.remove("active");
                if (body) body.style.display = "none";
            } else {
                this.classList.add("active");
                if (body) body.style.display = "block";
            }
        });
    });

    // --- 4. OUTSIDE CLICK (Updated to avoid conflicts) ---
    document.addEventListener("click", function(event) {
        // If the click is NOT inside a filter wrap, close everything
        if (!event.target.closest(".form-filter-wrap")) {
            document.querySelectorAll(".ff-in").forEach(el => {
                el.style.display = "none";
            });
            document.querySelectorAll(".ff-head").forEach(el => {
                el.classList.remove("active");
            });
        }
    });

    // Initial Bindings
    filterForm.onsubmit = (e) => {
        e.preventDefault();
        updateProductGrid();
        closeSidebar();
    };

    bindQuickPills();
    bindPaginationLinks();
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const content = document.getElementById('seoContent');
  const button = document.getElementById('seoToggleButton');

  if (content && button) {
    // Hide button if content is already short
    if (content.scrollHeight <= content.offsetHeight) {
      button.style.display = 'none';
    }

    button.addEventListener('click', function() {
      const isExpanded = content.classList.toggle('is-expanded');
      button.textContent = isExpanded ? 'Show Less' : 'Show More';

      // 1. Fix Lenis Scroll
      if (window.lenis) {
        window.lenis.resize();
      }

      // 2. Fix GSAP ScrollTrigger (since it's in your theme)
      if (window.ScrollTrigger) {
        window.ScrollTrigger.refresh();
      }
      
      // Optional: Smoothly scroll to the top of the section when closing
      if (!isExpanded) {
        content.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  }
});
</script>



<script>
   $(document).ready(function() {
      // Toggle logic
      $(".form-filter-wrap.list .ff-head").click(function(e) {
        e.stopPropagation(); 
        
        let $currentBody = $(this).siblings(".ff-in");
        let $currentHead = $(this);
        let $currentParent = $(this).parent(".form-filter-wrap.list");

        // If this one is already open, slide it up
        if ($currentHead.hasClass("active")) {
          $currentBody.slideUp(300).removeClass("active");
          $currentHead.removeClass("active");
          $currentParent.removeClass("active");
        } else {
          // Close any other open filters with a slideUp
          $(".list .ff-in").slideUp(300).removeClass("active");
          $(".list .ff-head").removeClass("active");
          $(".form-filter-wrap.list").removeClass("active");

          // Slide down the clicked one
          $currentBody.slideDown(300).addClass("active");
          $currentHead.addClass("active");
          $currentParent.addClass("active");
        }
      });

      // Close when clicking outside
      $(document).on("click", function(event) {
        if (!$(event.target).closest(".form-filter-wrap.list").length) {
          $(".list .ff-in").slideUp(300).removeClass("active");
          $(".list .ff-head").removeClass("active");
          $(".form-filter-wrap.list").removeClass("active");
        }
      });
    });

</script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
      const filter_button = document.querySelector('.filter-buttton');
      const filter_sidebar = document.querySelector('.filter-sidebar');
      const filter_close = document.querySelector('.filter-close-mob');

      // Open sidebar
      filter_button.addEventListener('click', function(e) {
          e.stopPropagation(); 
          filter_sidebar.classList.add('active');
          if (typeof lenis !== 'undefined') lenis.stop(); // Stop Lenis scrolling
      });

      // Close sidebar via close button
      filter_close.addEventListener('click', function() {
          filter_sidebar.classList.remove('active');
          if (typeof lenis !== 'undefined') lenis.start(); // Restart Lenis
      });

      // Close sidebar when clicking the BACKGROUND
      filter_sidebar.addEventListener('click', function(event) {
          // 'event.target' is the element you actually clicked
          // 'this' is the filter_sidebar itself
          // If they match, it means you clicked the background overlay, not the content inside
          if (event.target === this) {
              filter_sidebar.classList.remove('active');
              if (typeof lenis !== 'undefined') lenis.start();
          }
      });

      // Optional: Keep the document click as a fallback for the button area
      document.addEventListener('click', function(event) {
          const isClickOnButton = filter_button.contains(event.target);
          
          // If clicking somewhere else entirely that isn't the sidebar or button
          if (!filter_sidebar.contains(event.target) && !isClickOnButton) {
              filter_sidebar.classList.remove('active');
              if (typeof lenis !== 'undefined') lenis.start();
          }
      });
  });
</script>

{% schema %}
  {
    "name": "Collection",
    "tag": "section",
    "class": "collectionMain",
    "settings": [
      {
        "type": "text",
        "id": "head",
        "label": "Category Pages Heading"
      }
    ],
    "blocks": [
      {
        "type": "collection",
        "name": "Category Collections",
        "settings": [
          {
            "type": "collection",
            "id": "col",
            "label": "Select Collection"
          }, {
            "type": "text",
            "id": "col_name",
            "label": "Collection Name(optional)"
          }, {
            "type": "image_picker",
            "id": "col_img",
            "label": "Collection Image(optional)"
          }
        ]
      }
    ]
  }
{% endschema %}