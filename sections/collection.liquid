{% if collection.handle != 'all' %}
  {% comment %} <div class="collection-banner">
    <div class="container">
      <div class="cb-wrapper">
        <div class="heading center">
          <h1>{{ section.settings.head }}</h1>
        </div>
        <div class="cb-collection">
          {% for block in section.blocks %}
            {% assign collection_item = block.settings.col %}
            <a href="{{ collection_item.url }}" class="cbcIn">
              <div class="cbcImg">
                {% if collection_item.featured_image %}
                  <img src="{{ collection_item.featured_image | img_url: 'master' }}" alt="{{ collection_item.title }}">
                {% elsif block.settings.col_img %}
                  <img src="{{ block.settings.col_img | img_url: 'master' }}" alt="{{ collection_item.title }}">
                {% endif %}
              </div>

              <div class="cbcTxt">
                {% assign collection_title = block.settings.col_name %}
                {% if collection_title == '' %}
                  <p>{{ collection_item.title | strip_html | strip }}</p>
                {% else %}
                  <p>{{ block.settings.col_name }}</p>
                {% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </div> {% endcomment %}
{% endif %}
<div class="collection-banner">
  <div class="collection-main">
    <div class="container">
      <div class="cb-wrapper">
        <div class="breadcrumbs">
            <a href="{{ shop.url }}">Home</a>
            <p>
              >
            </p>
            <p>
              {% if collection.handle == 'all' %}
                All {{ collection.title }}
              {% else %}
                {{ collection.title }}
              {% endif %}
            </p>
          </div>
        {% comment %} <div class="heading">
          <h1>{{ section.settings.head }}</h1>
        </div> {% endcomment %}
        <div class="head">
          
          {% if collection.handle == 'all' %}
            <h1>All {{ collection.title }}</h1>
          {% else %}
            <h2>{{ collection.title }}</h2>
          {% endif %}
        </div> 
        <div class="cb-collection">
          {% for block in section.blocks %}
            {% assign collection_item = block.settings.col %}
            <a href="{{ collection_item.url }}" class="cbcIn">
              <div class="cbcImg">
                {% if collection_item.featured_image %}
                  <img src="{{ collection_item.featured_image | img_url: 'master' }}" alt="{{ collection_item.title }}">
                {% elsif block.settings.col_img %}
                  <img src="{{ block.settings.col_img | img_url: 'master' }}" alt="{{ collection_item.title }}">
                {% endif %}
              </div>

              <div class="cbcTxt">
                {% assign collection_title = block.settings.col_name %}
                {% if collection_title == '' %}
                  <p>{{ collection_item.title | strip_html | strip }}</p>
                {% else %}
                  <p>{{ block.settings.col_name }}</p>
                {% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      </div>
      <div class="cm-wrapper">
        {% comment %} <div class="head">
          
          {% if collection.handle == 'all' %}
            <h1>All {{ collection.title }}</h1>
          {% else %}
            <h2>{{ collection.title }}</h2>
          {% endif %}
        </div> {% endcomment %}
        <div class="tc-filter-wrap">
          <div class="filter-wrap filter">
            <div class="filter-buttton">
              Filter
              {% render 'filter-icon' %}
            </div>
            <div class="filter-sidebar">
              <div class="filtersidebar-in" data-lenis-prevent>
                <div class="filter-cross-div">
                  <p>
                    <span>Filter</span>
                    {% render 'filter-icon' %}</p>
                  <div class="filter-close-mob">
                    {% render 'cross' %}
                  </div>
                </div>
                <div class="filter-sidebar-form">

                  <form>

                    <div class="form-filter-wrap list">
                      <div class="ff-head">
                        <p>Sort By</p>
                        <div class="filter-down-arrow">
                          {% render "icon-arrow_down" %}
                        </div>
                      </div>
                      <div class="ff-in">
                        <ul>
                          {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
                        {% for option in collection.sort_options %}
                          <li>
                            <label for="sort-{{ forloop.index }}">
                              <input 
                                type="radio" 
                                name="sort_by" 
                                value="{{ option.value }}" 
                                id="sort-{{ forloop.index }}"
                                {% if option.value == sort_by %}checked{% endif %}
                              >
                              {{ option.name }}
                            </label>
                          </li>
                        {% endfor %}
                      </ul>
                    </div>
                  </div>

                    {%- for filter in collection.filters -%}
                      <div class="form-filter-wrap {{ filter.type }}">
                        <div class="ff-head">
                          <p>{{ filter.label }}</p>
                          <div class="filter-down-arrow">
                            {% render "icon-arrow_down" %}
                          </div>
                        </div>

                        <div class="ff-in">
                          {%- case filter.type -%}
                            {%- when 'boolean' -%}
                              <ul>
                                <li>
                                  <label for="Filter-{{ filter.param_name }}-{{ filter.true_value.value }}">
                                    <input
                                      type="radio"
                                      name="{{ filter.param_name }}"
                                      value="{{ filter.true_value.value }}"
                                      id="Filter-{{ filter.param_name }}"
                                      {% if filter.true_value.active -%}
                                      checked{%- endif %}
                                      {% if filter.true_value.count == 0 and filter.true_value.active == false -%}
                                      disabled{%- endif -%} />{{ filter.true_value.label }}</label>
                                </li>
                                <li>
                                  <label for="Filter-{{ filter.param_name }}-{{ filter.false_value.value }}">
                                    <input
                                      type="radio"
                                      name="{{ filter.param_name }}"
                                      value="{{ filter.false_value.value }}"
                                      id="Filter-{{ filter.param_name }}"
                                      {% if filter.false_value.active -%}
                                      checked{%- endif %}
                                      {% if filter.false_value.count == 0 and filter.false_value.active == false -%}
                                      disabled{%- endif %} />{{ filter.false_value.label }}</label>
                                </li>
                              </ul>
                            {%- when 'list' -%}
                              <ul>
                                {%- for filter_value in filter.values -%}
                                  <li>
                                    <label for="Filter-{{ filter.param_name }}-{{ forloop.index }}">
                                      <input
                                        type="checkbox"
                                        name="{{ filter_value.param_name }}"
                                        value="{{ filter_value.value }}"
                                        id="Filter-{{ filter.param_name }}-{{ forloop.index }}"
                                        {% if filter_value.active -%}
                                        checked{%- endif %}
                                        {% if filter_value.count == 0 and filter_value.active == false -%}
                                        disabled{%- endif %} />
                                      <span>
                                        {%- case filter_value.display.type -%}
                                          {%- when 'colors' -%}
                                            {% liquid
                                              assign size_limit = filter_value.display.value.size | at_most: 4
                                              assign rotation = '0deg'
                                              if size_limit == 2
                                                assign rotation = '45deg'
                                              endif

                                              assign angle_increment = 360 | divided_by: size_limit
                                              assign angle = 0
                                            %}
                                            {%- capture conic_gradient -%}
                                            {%- for color in filter_value.display.value limit: size_limit -%}
                                              {{ color }} {{ angle }}deg{%- assign angle = angle | plus: angle_increment %} {{ angle }}deg{%- unless forloop.last %}, {%- endunless -%}
                                            {%- endfor -%}
                                          {%- endcapture -%}
                                            <span style="width: '25px', height: '25px', borderRadius: '50%', display: 'flex', justifyContent: 'center', alignItems: 'center', background: 'conic-gradient({{ conic_gradient }})', transform: 'rotateZ({{ rotation }})'}}"></span>
                                          {%- when 'image' -%}
                                            {{
                                              filter_value.display.value | image_url: width: 25 | image_tag: alt: filter_value.display.value.alt
                                            }}
                                          {%- else -%}
                                            <span class="visual-display__child"></span>
                                        {%- endcase -%}
                                      </span>
                                      {{ filter_value.label }}
                                    </label>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- when 'price_range' -%}
                              <div class="filter-group-display__price-range">
                                <div class="range-slider">
                                    <!-- Range Inputs -->
                                  <input
                                    type="range"
                                    id="PriceRangeMin"
                                    min="0"
                                    max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                                    value="{{ filter.min_value.value | default: 0 | money_without_currency | replace: ',', '' }}"
                                    step="1">
                                  <input
                                    type="range"
                                    id="PriceRangeMax"
                                    min="0"
                                    max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                                    value="{{ filter.max_value.value | default: filter.range_max | money_without_currency | replace: ',', '' }}"
                                    step="1">

                                  <!-- Progress Track -->
                                  <div class="slider-track"></div>
                                </div>

                                <!-- Output Values -->
                                <div class="price-range-output">
                                  <span>{{ cart.currency.symbol }}
                                    <span id="PriceMinValue">{{ filter.min_value.value | default: 0 | money_without_currency | replace: ',', '' }}</span>
                                  </span>
                                  <span>{{ cart.currency.symbol }}
                                    <span id="PriceMaxValue">{{ filter.max_value.value | default: filter.range_max | money_without_currency | replace: ',', '' }}</span>
                                  </span>
                                </div>

                                <!-- Hidden Inputs for AJAX -->
                                <input
                                  type="hidden"
                                  name="{{ filter.min_value.param_name }}"
                                  id="HiddenPriceMin"
                                  value="{{ filter.min_value.value | default: 0 | money_without_currency | replace: ',', '' }}">
                                <input
                                  type="hidden"
                                  name="{{ filter.max_value.param_name }}"
                                  id="HiddenPriceMax"
                                  value="{{ filter.max_value.value | default: filter.range_max | money_without_currency | replace: ',', '' }}">
                              </div>
                          {%- endcase -%}
                        </div>
                      </div>
                    {%- endfor -%}
                    <div class="clear-filter">
                      <a href="{{ collection.url }}" class="reset-btn">Reset</a>
                      <button type="submit" class="apply-filter-btn custom-btn black">Apply Filters</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>
          <div class="quick-filters">
            <div class="qf-wrapper">
              <button type="button" class="qf-pill" 
                      data-name="filter.v.availability" 
                      data-value="1">
                In Stock
              </button>

              <button type="button" class="qf-pill" 
                      data-name="filter.v.availability" 
                      data-value="0">
                Out Of Stock
              </button>

              <button type="button" class="qf-pill clear-all-pill" style="display: none;">
                Clear All ✕
              </button>
            </div>
          </div>
          {% comment %} <div class="filter-wrap sort-by">
            <select id="sort-by">
              {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
              <option
                value=""
                disabled
                selected>Sort by</option>
              {% for option in collection.sort_options %}
                <option
                  value="{{ option.value }}"
                  {% if option.value == sort_by %}
                  style="display:none"
                  {% endif %}>
                  {{ option.name }}
                </option>
              {% endfor %}
            </select>
          </div> {% endcomment %}
        </div>
        <div class="collection-wrapper" id="ProductGrid">
          {% paginate collection.products by section.settings.number_of_product %}
            {% for product in collection.products %}
              {% render 'product-card-primary' | product: product %}
            {% endfor %}
            {% render 'pagination' | pagination: paginate %}
          {% endpaginate %}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
      const quickFilterButtons = document.querySelectorAll('.qf-pill:not(.clear-all-pill)');
      const clearAllBtn = document.querySelector('.clear-all-pill');
      const filterForm = document.querySelector(".tc-filter-wrap form");
      const productGrid = document.querySelector("#ProductGrid");
      const sortBy = document.querySelector("#sort-by");

      if (!filterForm || !productGrid) return;

      // --- NEW: PILL & RESET UTILITIES ---
      function toggleClearAllVisibility() {
        if (!clearAllBtn) return;
        // Check for any checked inputs that aren't the sort_by radio
        const hasActiveFilters = Array.from(filterForm.querySelectorAll('input[type="checkbox"], input[type="radio"]'))
          .some(input => input.checked && input.name !== 'sort_by');
        clearAllBtn.style.display = hasActiveFilters ? 'inline-block' : 'none';
      }

      function syncPillStates() {
        quickFilterButtons.forEach(button => {
          const name = button.getAttribute('data-name');
          const value = button.getAttribute('data-value');
          const checkbox = filterForm.querySelector(`input[name="${name}"][value="${value}"]`);
          if (checkbox && checkbox.checked) {
            button.classList.add('is-active');
          } else {
            button.classList.remove('is-active');
          }
        });
      }

      function updateProductGrid(extraParams = {}, urlOverride = null) {
        const formData = new FormData(filterForm);
        const searchParams = new URLSearchParams(formData);

        Object.keys(extraParams).forEach((key) => {
          searchParams.set(key, extraParams[key]);
        });

        let url = urlOverride ? urlOverride : `${window.location.pathname}?${searchParams.toString()}`;

        fetch(url)
          .then((res) => res.text())
          .then((data) => {
            const parser = new DOMParser();
            const newDoc = parser.parseFromString(data, "text/html");

            const newGrid = newDoc.querySelector("#ProductGrid");
            if (newGrid) {
              productGrid.innerHTML = newGrid.innerHTML;
            }

            // Update UI States for Pills
            toggleClearAllVisibility();
            syncPillStates();

            if (typeof lenis !== 'undefined') {
              lenis.resize(); 
            }

            window.history.pushState({}, "", url);
            bindPaginationLinks();

            const offset = 100;
            const topPos = productGrid.getBoundingClientRect().top + window.pageYOffset - offset;
            
            if (typeof lenis !== 'undefined') {
              lenis.scrollTo(topPos, { lerp: 0.1 });
            } else {
              window.scrollTo({ top: topPos, behavior: "smooth" });
            }
          })
          .catch((err) => console.error("Filter update error:", err));
      }

      // === Quick Pill Logic ===
      quickFilterButtons.forEach(button => {
        button.addEventListener('click', function() {
          const filterName = this.getAttribute('data-name');
          const filterValue = this.getAttribute('data-value');
          const checkbox = filterForm.querySelector(`input[name="${filterName}"][value="${filterValue}"]`);

          if (checkbox) {
            checkbox.checked = !checkbox.checked;
            updateProductGrid(); // Instant apply
          }
        });
      });

      // === Clear All Logic ===
      if (clearAllBtn) {
        clearAllBtn.addEventListener('click', function() {
          filterForm.reset();
          // Manually uncheck everything because form.reset() doesn't always trigger change
          filterForm.querySelectorAll('input').forEach(input => input.checked = false);
          updateProductGrid();
        });
      }

      // === Filter Handling (Apply Button) ===
      filterForm.addEventListener("submit", function (e) {
        e.preventDefault();
        updateProductGrid();
        
        const filter_sidebar = document.querySelector('.filter-sidebar');
        filter_sidebar.classList.remove('active');
        if (typeof lenis !== 'undefined') lenis.start();
      });

      // === Pagination Handling ===
      function bindPaginationLinks() {
        const paginationLinks = document.querySelectorAll(".pagination a");
        paginationLinks.forEach((link) => {
          link.addEventListener("click", function (e) {
            e.preventDefault();
            updateProductGrid({}, this.getAttribute("href"));
          });
        });
      }
      bindPaginationLinks();

      // === Price Slider ===
      const priceMin = document.querySelector("#PriceRangeMin");
      const priceMax = document.querySelector("#PriceRangeMax");
      const priceMinOutput = document.querySelector("#PriceMinValue");
      const priceMaxOutput = document.querySelector("#PriceMaxValue");
      const hiddenMin = document.querySelector("#HiddenPriceMin");
      const hiddenMax = document.querySelector("#HiddenPriceMax");
      const sliderTrack = document.querySelector(".slider-track");

      if (priceMin && priceMax && priceMinOutput && priceMaxOutput && hiddenMin && hiddenMax && sliderTrack) {
        function updateSliderTrack() {
          const minVal = parseInt(priceMin.value);
          const maxVal = parseInt(priceMax.value);
          const rangeMax = parseInt(priceMax.max);
          const percent1 = (minVal / rangeMax) * 100;
          const percent2 = (maxVal / rangeMax) * 100;
          sliderTrack.style.background = `linear-gradient(to right, #ddd ${percent1}%, #000 ${percent1}%, #000 ${percent2}%, #ddd ${percent2}%)`;
        }

        function syncValues() {
          let minVal = parseInt(priceMin.value);
          let maxVal = parseInt(priceMax.value);
          if (minVal > maxVal) [minVal, maxVal] = [maxVal, minVal];
          priceMinOutput.textContent = minVal;
          priceMaxOutput.textContent = maxVal;
          hiddenMin.value = minVal;
          hiddenMax.value = maxVal;
          updateSliderTrack();
        }

        syncValues();
        priceMin.addEventListener("input", syncValues);
        priceMax.addEventListener("input", syncValues);
      }

      // Initial check on page load
      toggleClearAllVisibility();
      syncPillStates();
  });
  

</script>



<script>
   $(document).ready(function() {
      // Toggle logic
      $(".form-filter-wrap.list .ff-head").click(function(e) {
        e.stopPropagation(); 
        
        let $currentBody = $(this).siblings(".ff-in");
        let $currentHead = $(this);
        let $currentParent = $(this).parent(".form-filter-wrap.list");

        // If this one is already open, slide it up
        if ($currentHead.hasClass("active")) {
          $currentBody.slideUp(300).removeClass("active");
          $currentHead.removeClass("active");
          $currentParent.removeClass("active");
        } else {
          // Close any other open filters with a slideUp
          $(".list .ff-in").slideUp(300).removeClass("active");
          $(".list .ff-head").removeClass("active");
          $(".form-filter-wrap.list").removeClass("active");

          // Slide down the clicked one
          $currentBody.slideDown(300).addClass("active");
          $currentHead.addClass("active");
          $currentParent.addClass("active");
        }
      });

      // Close when clicking outside
      $(document).on("click", function(event) {
        if (!$(event.target).closest(".form-filter-wrap.list").length) {
          $(".list .ff-in").slideUp(300).removeClass("active");
          $(".list .ff-head").removeClass("active");
          $(".form-filter-wrap.list").removeClass("active");
        }
      });
    });

</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
      const filter_button = document.querySelector('.filter-buttton');
      const filter_sidebar = document.querySelector('.filter-sidebar');
      const filter_close = document.querySelector('.filter-close-mob');

      // Open sidebar
      filter_button.addEventListener('click', function(e) {
          e.stopPropagation(); // Prevents the document listener from firing immediately
          filter_sidebar.classList.add('active');
      });

      // Close sidebar via close button
      filter_close.addEventListener('click', function() {
          filter_sidebar.classList.remove('active');
      });

      // Close sidebar when clicking outside
      document.addEventListener('click', function(event) {
          const isClickInsideSidebar = filter_sidebar.contains(event.target);
          const isClickOnButton = filter_button.contains(event.target);

          // If the click happened outside both the sidebar and the open button
          if (!isClickInsideSidebar && !isClickOnButton) {
              filter_sidebar.classList.remove('active');
          }
      });
  });
</script>

{% schema %}
  {
    "name": "Collection",
    "tag": "section",
    "class": "collectionMain",
    "settings": [
      {
        "type": "text",
        "id": "head",
        "label": "Category Pages Heading"
      }
    ],
    "blocks": [
      {
        "type": "collection",
        "name": "Category Collections",
        "settings": [
          {
            "type": "collection",
            "id": "col",
            "label": "Select Collection"
          }, {
            "type": "text",
            "id": "col_name",
            "label": "Collection Name(optional)"
          }, {
            "type": "image_picker",
            "id": "col_img",
            "label": "Collection Image(optional)"
          }
        ]
      }
    ]
  }
{% endschema %}