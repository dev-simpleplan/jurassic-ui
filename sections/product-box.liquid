<link
  rel="stylesheet"
  type="text/css"
  href="//cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css" />
<script
  type="text/javascript"
  src="//cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"
  defer></script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />
<script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>

<div class="pro-breadcrumbs">
  <div class="container">
      <div class="bcrum-in">
        <ul>
          <li><a href="{{ routes.root_url }}">Home</a></li>

          {%- liquid
            assign selected_col = nil
            # Define the handles you want to skip
            assign generic_handles = "all,all-products,all-fruits,all-fruit,all-collections,shop-all,alle-produkte,alle-fruchte,alle-fruechte,tous-les-produits,tous-les-fruits,frontpage,best-seller" | split: ","
            
            # 1. Check if we are currently in a valid collection
            if collection
              assign is_generic = false
              if generic_handles contains collection.handle or collection.handle contains 'all-' or collection.handle contains 'alle-' or collection.handle contains 'tous-les-'
                assign is_generic = true
              endif

              if is_generic == false
                assign selected_col = collection
              endif
            endif

            # 2. If no collection selected yet, loop through product collections
            if selected_col == nil
              for col in product.collections
                if generic_handles contains col.handle or col.handle contains 'all-' or col.handle contains 'alle-' or col.handle contains 'tous-les-'
                  continue
                else
                  assign selected_col = col
                  break
                endif
              endfor
            endif
          -%}

          {%- if selected_col -%}
            <li>
              <a href="{{ selected_col.url }}">
                {{ selected_col.title }}
              </a>
            </li>
          {%- endif -%}

          <li>
            <span>{{ product.title }}</span>
          </li>
        </ul>
      </div>
  </div>
</div>

{% assign default_variant = nil %}

{% for variant in product.variants %}
  {% if variant.metafields.custom.is_prior == true and variant.available %}
    {% assign default_variant = variant %}
    {% break %}
  {% endif %}
{% endfor %}

{% if default_variant == nil %}
  {% for variant in product.variants %}
    {% if variant.available %}
      {% assign default_variant = variant %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if default_variant == nil %}
  {% assign default_variant = product.variants.first %}
{% endif %}

{% assign selected_variant = default_variant %}
{% assign show_product_testimonial = false %}
{% for testimonial_block in section.blocks %}
  {% if testimonial_block.settings.show_testimonial and product.metafields.custom.title_testimonial != blank %}
    {% assign show_product_testimonial = true %}
    {% break %}
  {% endif %}
{% endfor %}
<div class="product-info">
  <div class="container">
    <div class="pro-grid">
      <div class="pro-img-wrap">
          <div class="pro-img">
            <div class="pro-right-side">
              <div class="prs-data">
                {% if product.tags.size > 0 %}
                    <div class="fc_category_tags">
                      {% if product.metafields.custom.certificate %}
                        {% assign certificate = product.metafields.custom.certificate.value %}
                        {% for item in product.metafields.custom.certificate.value %}
                          <div class="fc_organic_auth">
                            <img
                              src="{{ item.badge_image | img_url:'master' }}"
                              alt="{{ item.display_name }}"
                              class="img_sizing">
                          </div>
                        {% endfor %}
                      {% endif %}

                      {% if product.metafields.custom.quality_label != blank %}
                        <span>{{ product.metafields.custom.quality_label.value | default: product.metafields.custom.quality_label }}</span>
                      {% endif %}

                      {% comment %}
                        {% for tag in product.tags %}
                          {% unless tag == 'Best Seller' %}
                            <span>{{ tag }}</span>
                          {% endunless %}
                        {% endfor %}
                      {% endcomment %}
                    </div>
                  {% endif %}

                  {% if product.tags contains 'Best Seller' %}
                    <div class="fc_bestsell_tags">
                      <span>Bestseller</span>
                    </div>
                  {% endif %}
              </div>
              <div class="prod-main-image">
                {% if product.media.size > 0 %}
                  {% for media in product.media %}
                    <div class="item" data-media-id="{{ media.id }}">
                      <div class="prod-main">
                        <a href="{{ media | img_url: 'master' }}" data-fancybox="gallery-box" class="zoom-wrapper">
                          {% render 'product-media', media: media %}
                        </a>
                      </div>
                    </div>
                  {% endfor %}
                {% else %}
                  {% comment %} This renders ONLY if there are no images/videos {% endcomment %}
                  <div class="item">
                    <div class="prod-main">
                      <img
                        src="https://cdn.shopify.com/s/files/1/0752/8015/4881/files/jf-placeholder.png?v=1769522647"
                        alt="{{ product.title }}"
                        class="image-custom"
                        loading="lazy">
                    </div>
                  </div>
                {% endif %}
              </div>
              <div class="product-gallery-counter" aria-live="polite">
                <span data-gallery-current>1</span>/<span data-gallery-total>{% if product.media.size > 0 %}{{ product.media.size }}{% else %}1{% endif %}</span>
              </div>
              <div class="btn-wrap">
                <button class="custom-prev">
                  {%- render 'arrow-prev' -%}
                </button>
                <button class="custom-next">
                  {%- render 'arrow-next' -%}
                </button>
              </div>
            </div>
            <div class="prod-thumb-image">
              {% if product.media.size > 0 %}
                {% for media in product.media %}
                  <div class="item" data-media-id="{{ media.id }}">
                    <div class="prod-thumb">
                      {% render 'product-media', media: media %}
                    </div>
                  </div>
                {% endfor %}
              {% else %}
                {% comment %} Show a small thumbnail placeholder if no media exists {% endcomment %}
                <div class="item">
                  <div class="prod-thumb">
                    <img
                      src="https://cdn.shopify.com/s/files/1/0752/8015/4881/files/jf-placeholder.png?v=1769522647"
                      alt="Placeholder"
                      class="image-custom thumb-placeholder"
                      loading="lazy">
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
          {% if show_product_testimonial %}
            <div class="pro-test">
              {% for block in section.blocks %}
                {% if block.settings.show_testimonial and product.metafields.custom.title_testimonial != blank %}
                  <div class="tr-testimonial">
                    {% render 'testimonial-icon' %}
                    {{ product.metafields.custom.title_testimonial | metafield_tag }}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
       </div>
      <div class="pro-desp">
        {% form 'product'
          , product
          , id: 'product-form'
          , novalidate: 'novalidate' %}
          <input
            type="hidden"
            name="id"
            value="{{ selected_variant.id }}">

            {% for block in section.blocks %}
            {% case block.type %}
              {% when 'title' %}
                <div class="title">
                  <div class="title-review">
                    {% comment %} {% if block.settings.show_testimonial 
                      and product.metafields.custom.title_testimonial != blank %}
                      <div class="tr-testimonial">
                        {% render 'testimonial-icon' %}
                        {{ product.metafields.custom.title_testimonial | metafield_tag }}
                      </div>
                    {% endif %} {% endcomment %}

                    <!-- OKENDO APP BLOCK BESIDE TESTIMONIAL -->
                    <div class="tr-okendo">
                      <p data-oke-star-rating data-oke-reviews-product-id="shopify-{{ product.id }}"></p>
                    </div>

                    {% assign certificate = product.metafields.custom.certificate %}
                    <div class="tr-review-certi">
                      <div class="ts-certificate">
                        {% if certificate != '' %}
                          {% for item in certificate.value %}
                            <div class="tsc-img">
                              <img src="{{ item.badge_image |  img_url: 'master' }}" alt="{{ item.display_name }}" class="img">
                            </div>
                          {% endfor %}
                        {% endif %}
                      </div>
                    </div>
                  </div>
                  <h1>{{ product.title }}</h1>
                    <div class="price" id="price-{{ section.id }}">
                      <div class="price-detailsss"> 

                        <div class="pd-top">
                          {% assign currency_suffix = cart.currency.symbol %}
                         <div class="sell-price {% unless selected_variant.compare_at_price > selected_variant.price %}withoutbg{% endunless %}">
                            {{ selected_variant.price | money_without_currency }} {{ cart.currency.symbol }}
                          </div>

                          <strike class="real-price">
                            {{ selected_variant.compare_at_price | money_without_currency }} {{ cart.currency.symbol }}
                          </strike>

                          {% if selected_variant.compare_at_price > selected_variant.price %}
                            <span class="off-percent" data-price-off-percent>
                              -{{ selected_variant.compare_at_price | minus: selected_variant.price | times: 100 | divided_by: selected_variant.compare_at_price | round }}%
                            </span>
                          {% endif %}
                        </div>

                        <div class="pd-bottom" {% unless selected_variant.unit_price_measurement %}style="display:none;"{% endunless %}>
                          <span class="sell-price-variant-perkg">
                            {% if selected_variant.unit_price_measurement %}
                              {{ selected_variant.unit_price | money_without_currency }} {{ cart.currency.symbol }} / {{ selected_variant.unit_price_measurement.reference_unit }}
                            {% endif %}
                          </span>
                        </div>
                        <!-- ALWAYS present -->
                      </div>

                      <span class="price-txt">
                        {{ 'sections.product.price_includes_vat' | t }} <a href="javascript:void()">{{ 'sections.product.shipping_costs' | t }}</a>
                      </span>
                    </div>

                </div>

              {% when 'product_info' %}
                <div class="product-info-block">
                  {% if show_product_testimonial %}
                    <div class="pro-test formobile">
                      {% for block in section.blocks %}
                        {% if block.settings.show_testimonial
                          and product.metafields.custom.title_testimonial != blank %}
                          {% comment %} <div class="tr-okendo">
                            <p data-oke-star-rating data-oke-reviews-product-id="shopify-{{ product.id }}"></p>
                          </div> {% endcomment %}
                          <div class="tr-testimonial">
                            {% render 'testimonial-icon' %}
                            {{ product.metafields.custom.title_testimonial | metafield_tag }}
                          </div>
                        {% endif %}
                      {% endfor %}
                    </div>
                  {% endif %}
                  {% comment %} For Origin {% endcomment %}
                  {% comment %} <div class="pi-item">
                    {% render 'green-tick' %}
                    <div class="pii-info">
                      <p>
                        <strong>Origin:</strong>
                        {{ product.metafields.custom.country_of_origin.value.country_name }}
                      </p>
                    </div>
                  </div> {% endcomment %}
                  {% comment %} Seasonality {% endcomment %}
                  {% comment %} <div class="pi-item">
                    {% render 'green-tick' %}
                    <div class="pii-info">
                      <p>
                        <strong>Seasonality:</strong>
                        {{ product.metafields.custom.country_season.value.season.value.seasonality }}
                      </p>
                    </div>
                  </div> {% endcomment %}

                  {% comment %} Additional Information {% endcomment %}

                  {% for item in product.metafields.custom.additional_information.value %}
                    <div class="pi-item">
                      {% render 'green-tick' %}
                      <div class="pii-info">
                        <p>
                          <strong>{{ item.inforamation_title }}</strong>
                          {{ item.information_paragraph }}
                        </p>
                      </div>
                    </div>
                  {% endfor %}

                </div>

              {% when 'box_content' %}
                <div class="boxIn">
                  {% comment %} Main Box Content {% endcomment %}
                  {% if product.metafields.custom.main_box_content.value != blank %}
                    <div class="box-content">
                      <div class="box-content-title">
                        Main Fruits
                      </div>
                      <div class="box-content-in">
                        {% for item in product.metafields.custom.main_box_content.value %}
                          <div class="cotent-item">{{ item.title }}</div>
                        {% endfor %}
                      </div>
                    </div>
                  {% endif %}
                  {% comment %} Additional Box Content {% endcomment %}
                  {% if product.metafields.custom.additional_box_content.value != blank %}
                    <div class="box-content">
                      <div class="box-content-title">
                        Additional Fruits
                      </div>
                      <div class="box-content-in">
                        {% for item in product.metafields.custom.additional_box_content.value %}
                          <div class="cotent-item">{{ item.title }}</div>
                        {% endfor %}
                      </div>
                    </div>
                  {% endif %}
                </div>

              {% when 'store_usp' %}
                <div class="store-usp">
                  {% comment %} For Shipping USP {% endcomment %}
                  <div class="su-item">
                    <div class="sui-icon">
                      <img src="{{ block.settings.shipping_usp_icon |  img_url: 'master' }}" alt="{{ block.settings.shipping_usp_text }}">
                    </div>
                    {% comment %} <div class="sui-txt">
                      <a href="{{ block.settings.shipping_usp_page.url }}">{{ block.settings.shipping_usp_text }}</a>
                    </div> {% endcomment %}
                    <div class="sui-txt">
                      <span
                        id="delivery-data"
                        class="shipping-policy-popup usp-modal-trigger"
                        data-modal-target="shipping-modal-box">
                        {{ block.settings.shipping_usp_text }}
                      </span>
                    </div>

                    <div id="shipping-modal-box" class="shipping-modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="shipping-modal-title-box">
                      <div class="shipping-modal-container">
                        <div class="shipping-modal-header">
                          <h2 id="shipping-modal-title-box">{{ 'general.shipping_policy' | t | default: 'Shipping Policy' }}</h2>
                          <span class="shipping-modal-close" aria-label="Close modal" role="button" tabindex="0">&times;</span>
                        </div>
                        <div class="shipping-modal-body" data-lenis-prevent>
                          <div class="shipping-modal-content">
                            {{ shop.shipping_policy.body }}
                          </div>
                        </div>
                      </div>
                    </div>



                    <script>
                      (function () {
                        const trigger = document.querySelector('.shipping-policy-popup');
                        const modal = document.getElementById('shipping-modal-box');
                        if (!trigger || !modal) return;

                        const closeBtn = modal.querySelector('.shipping-modal-close');

                        function openModal(e) {
                          e.preventDefault();
                          modal.classList.add('is-open');
                          modal.setAttribute('aria-hidden', 'false');
                          document.body.style.overflow = 'hidden';
                          closeBtn.focus();
                        }

                        function closeModal() {
                          modal.classList.remove('is-open');
                          modal.setAttribute('aria-hidden', 'true');
                          document.body.style.overflow = '';
                          trigger.focus();
                        }

                        trigger.addEventListener('click', openModal);
                        closeBtn.addEventListener('click', closeModal);

                        modal.addEventListener('click', function (e) {
                          if (e.target === modal) closeModal();
                        });

                        document.addEventListener('keydown', function (e) {
                          if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
                        });
                      })();
                    </script>
                  </div>

                  {% comment %} For Freshness USP {% endcomment %}
                  {% if product.metafields.custom.fresh_product != true %}

                  {% else %}
                    <div class="su-item">
                      <div class="sui-icon">
                        <img src="{{ block.settings.freshness_icon |  img_url: 'master' }}" alt="{{ 'sections.product.freshness_usp' | t | default: block.settings.freshness_text }}">
                      </div>
                      <div class="sui-txt">
                        <span
                          class="usp-modal-trigger"
                          role="button"
                          tabindex="0"
                          data-modal-target="freshness-modal-box-{{ section.id }}">
                          {{ 'sections.product.freshness_usp' | t | default: block.settings.freshness_text }}
                        </span>
                      </div>
                    </div>
                  {% endif %}

                  {% comment %} For Payment USP {% endcomment %}
                  <div class="su-item">
                    <div class="sui-icon">
                      <img src="{{ block.settings.payment_usp_icon |  img_url: 'master' }}" alt="{{ 'sections.product.payment_usp' | t | default: block.settings.payment_usp_text }}">
                    </div>
                    <div class="sui-txt">
                      <span
                        class="usp-modal-trigger"
                        role="button"
                        tabindex="0"
                        data-modal-target="payment-modal-box-{{ section.id }}">
                        {{ 'sections.product.payment_usp' | t | default: block.settings.payment_usp_text }}
                      </span>
                    </div>
                  </div>

                  <div id="freshness-modal-box-{{ section.id }}" class="shipping-modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="freshness-modal-title-box-{{ section.id }}">
                    <div class="shipping-modal-container">
                      <div class="shipping-modal-header">
                        <h2 id="freshness-modal-title-box-{{ section.id }}">{{ 'sections.product.freshness_modal_title' | t }}</h2>
                        <span class="shipping-modal-close" aria-label="Close modal" role="button" tabindex="0">&times;</span>
                      </div>
                      <div class="shipping-modal-body" data-lenis-prevent>
                        <div class="shipping-modal-content">
                          <p>{{ 'sections.product.freshness_modal_body' | t }}</p>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div id="payment-modal-box-{{ section.id }}" class="shipping-modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="payment-modal-title-box-{{ section.id }}">
                    <div class="shipping-modal-container">
                      <div class="shipping-modal-header">
                        <h2 id="payment-modal-title-box-{{ section.id }}">{{ 'sections.product.payment_modal_title' | t }}</h2>
                        <span class="shipping-modal-close" aria-label="Close modal" role="button" tabindex="0">&times;</span>
                      </div>
                      <div class="shipping-modal-body" data-lenis-prevent>
                        <div class="shipping-modal-content">
                          <p>{{ 'sections.product.payment_modal_body' | t }}</p>
                        </div>
                      </div>
                    </div>
                  </div>

                  <script>
                    (function () {
                      document.querySelectorAll('.usp-modal-trigger').forEach(function (trigger) {
                        if (trigger.dataset.uspModalBound === 'true') return;

                        const modal = document.getElementById(trigger.dataset.modalTarget);
                        if (!modal) return;

                        const closeBtn = modal.querySelector('.shipping-modal-close');
                        if (!closeBtn) return;

                        function openModal(e) {
                          e.preventDefault();
                          modal.classList.add('is-open');
                          modal.setAttribute('aria-hidden', 'false');
                          document.body.style.overflow = 'hidden';
                          closeBtn.focus();
                        }

                        function closeModal() {
                          modal.classList.remove('is-open');
                          modal.setAttribute('aria-hidden', 'true');
                          document.body.style.overflow = '';
                          trigger.focus();
                        }

                        trigger.dataset.uspModalBound = 'true';
                        trigger.addEventListener('click', openModal);
                        trigger.addEventListener('keydown', function (e) {
                          if (e.key === 'Enter' || e.key === ' ') openModal(e);
                        });
                        closeBtn.addEventListener('click', closeModal);
                        closeBtn.addEventListener('keydown', function (e) {
                          if (e.key === 'Enter' || e.key === ' ') closeModal();
                        });
                        modal.addEventListener('click', function (e) {
                          if (e.target === modal) closeModal();
                        });
                        document.addEventListener('keydown', function (e) {
                          if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
                        });
                      });
                    })();
                  </script>
                </div>

              {% when 'variant_selector' %}
                <div class="variant">
                  <div class="variant-wrapper">
                    {% unless product.has_only_default_variant %}
                    <div class="select_variant">
                        <variant-selector data-url="{{ product.url }}" data-section="{{ section.id }}">
                          <div class="sv-perKg">
                            <p>{{ 'sections.product.select_variant' | t }}</p>
                            <div class="perKg">
                              {% comment %} Kept for layout parity; button state below becomes the source of truth. {% endcomment %}
                              {% assign selected_variant_pieces = selected_variant.metafields.custom.pieces.value | default: selected_variant.metafields.custom.pieces %}
                              {% if selected_variant_pieces != blank %}
                                ( {{ selected_variant_pieces }} )
                              {% endif %}
                            </div>
                          </div>
                          {% for option in product.options_with_values %}
                            {% assign option_index = forloop.index0 %}
                            {% assign selected_option_value = selected_variant.options[option_index] %}
                            <div class="variant-option" data-option="{{ option.name }}">
                              <ul class="variant-values" data-index="{{ forloop.index0 }}">
                                {% for value in option.values %}
                                  {% assign matched_variant = nil %}
                                  {% assign available_matched_variant = nil %}

                                  {% for variant in product.variants %}
                                    {% case option.position %}
                                      {% when 1 %}
                                        {% if variant.option1 == value %}
                                          {% if matched_variant == nil %}
                                            {% assign matched_variant = variant %}
                                          {% endif %}
                                          {% if variant.available %}
                                            {% assign available_matched_variant = variant %}
                                            {% break %}
                                          {% endif %}
                                        {% endif %}
                                      {% when 2 %}
                                        {% if variant.option2 == value %}
                                          {% if matched_variant == nil %}
                                            {% assign matched_variant = variant %}
                                          {% endif %}
                                          {% if variant.available %}
                                            {% assign available_matched_variant = variant %}
                                            {% break %}
                                          {% endif %}
                                        {% endif %}
                                      {% when 3 %}
                                        {% if variant.option3 == value %}
                                          {% if matched_variant == nil %}
                                            {% assign matched_variant = variant %}
                                          {% endif %}
                                          {% if variant.available %}
                                            {% assign available_matched_variant = variant %}
                                            {% break %}
                                          {% endif %}
                                        {% endif %}
                                    {% endcase %}
                                  {% endfor %}
                                  {% assign matched_variant = available_matched_variant | default: matched_variant %}

                                  {% if matched_variant == nil %}
                                    {% continue %}
                                  {% endif %}

                                  {% if product.available and matched_variant.available != true %}
                                    {% continue %}
                                  {% endif %}

                                  {% assign matched_variant_pieces = matched_variant.metafields.custom.pieces.value | default: matched_variant.metafields.custom.pieces %}

                                  <li
                                    class="variant-value {% if selected_option_value == value %}active{% endif %}{% unless matched_variant.available %} is-sold-out{% endunless %}"
                                    data-value="{{ value | escape }}"
                                    data-available="{{ matched_variant.available }}"
                                    {% if matched_variant.metafields.custom.bestseller == true %}
                                    data-best="bestseller"
                                    {% endif %}>
                                    {% if matched_variant.metafields.custom.bestseller == true %}
                                      <div class="vv-bestseller">{{ 'sections.product.best_seller' | t }}</div>
                                    {% endif %}
                                    <div class="vv-value">
                                      <div class="vvv-value">
                                        {{ value }}
                                      </div>
                                      <div class="perKg">
                                        {% comment %} {% if matched_variant.unit_price_measurement %}
                                          {{ matched_variant.unit_price | money }} / {{ matched_variant.unit_price_measurement.reference_unit }}
                                        {% comment %} {{ matched_variant.unit_price_measurement.reference_value }} {% endcomment %}
                                        {% else %}
                                          {{ matched_variant.price | money }} / unit
                                        {% endif %} {% endcomment %}
                                        {% if matched_variant_pieces != blank %}
                                          ( {{ matched_variant_pieces }} )
                                        {% endif %}
                                      </div>
                                    </div>
                                    {% if matched_variant.unit_price_measurement %}
                                    <div class="vv-peices">
                                      {% assign currency_suffix = cart.currency.symbol %}
                                      {{ matched_variant.unit_price | money_without_currency }} {{ currency_suffix }} / {{ matched_variant.unit_price_measurement.reference_unit }}
                                    </div>
                                    {% endif %}
                                  </li>
                                {% endfor %}
                              </ul>
                            </div>
                          {% endfor %}

                          <script type="application/json">
                            [
                              {% for variant in product.variants %}
                                {
                                  "id": {{ variant.id | json }},
                                  "available": {{ variant.available | json }},
                                  "price": {{ variant.price | json }},
                                  "compare_at_price": {{ variant.compare_at_price | json }},
                                  "unit_price": {{ variant.unit_price | json }},
                                  "unit_price_reference_unit": {{ variant.unit_price_measurement.reference_unit | json }},
                                  "featured_media_id": {{ variant.featured_media.id | json }},
                                  "options": {{ variant.options | json }}
                                }{% unless forloop.last %},{% endunless %}
                              {% endfor %}
                            ]
                          </script>
                        </variant-selector>
                    </div>
                    {% endunless %}
                    <div class="priceCheckout">
                      
                      <div class="submit submit--with-qty">
                        <div class="qty-selector">
                          <button type="button" class="qty-btn minus" data-action="decrease">−</button>
                          <input
                            type="number"
                            name="quantity"
                            id="Quantity"
                            value="1"
                            min="1"
                          >
