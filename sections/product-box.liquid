  <script>
  /* ======================================================
     GLOBAL MONEY FORMATTER (USED EVERYWHERE)
  ====================================================== */
  window.formatMoneySafe = function (cents) {
    if (typeof cents !== 'number') return '';
    return new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: Shopify?.currency?.active || '{{ shop.currency }}',
      minimumFractionDigits: 2
    }).format(cents / 100);
  };
  </script>

  <script>
  /* ======================================================
     QUANTITY CONTROLLER (NO PRICE LOGIC HERE)
  ====================================================== */
  document.addEventListener('DOMContentLoaded', () => {
    const qtyInput = document.getElementById('Quantity');
    if (!qtyInput) return;

    document.querySelectorAll('.qty-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        let qty = parseInt(qtyInput.value, 10) || 1;
        qty = btn.dataset.action === 'increase' ? qty + 1 : Math.max(1, qty - 1);
        qtyInput.value = qty;
        document.dispatchEvent(new Event('quantity:change'));
      });
    });

    qtyInput.addEventListener('change', () => {
      document.dispatchEvent(new Event('quantity:change'));
    });
  });
  </script>

  <script>
  /* ======================================================
     ADD TO CART BUTTON STATE
  ====================================================== */
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('add-to-cart');
    const form = document.getElementById('product-form');

    if (!btn || !form) return;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      event.stopPropagation();

      if (btn.classList.contains('loading')) return;

      btn.classList.remove('success');
      btn.classList.add('loading');
      btn.disabled = true;

      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          body: new FormData(form),
          headers: {
            Accept: 'application/json'
          }
        });

        if (!response.ok) {
          throw new Error(`Add to cart failed: ${response.status}`);
        }

              /* Update cart count */
      const cart = await fetch('/cart.js').then(r => r.json());

      document.querySelectorAll('[data-ajax-cart-bind="item_count"]').forEach(el => {
        el.textContent = cart.item_count;
        el.classList.toggle('is-hidden', cart.item_count === 0);
      });

      btn.classList.remove('loading');
      btn.classList.add('success');

      document.dispatchEvent(new CustomEvent('cart:updated'));
        window.setTimeout(() => {
          document.querySelector('.cart-open, #corner-cowi-open-primary-card')?.click();
        }, 100);
      } catch (error) {
        console.error('Product box add to cart failed', error);
        btn.classList.remove('loading');
        btn.disabled = false;
        return;
      }

      window.setTimeout(() => {
        btn.classList.remove('loading', 'success');
        btn.disabled = false;
      }, 1200);
    });
  });
  </script>

  <script defer>
  /* ======================================================
     VARIANT SELECTOR (SINGLE SOURCE OF TRUTH)
  ====================================================== */
  class VariantSelector extends HTMLElement {
    constructor() {
      super();
      this.addEventListener('click', this.onVariantClick.bind(this));
    }

    connectedCallback() {
      const urlParams = new URLSearchParams(window.location.search);
      const initialVariantId =
        Number(urlParams.get('variant')) || {{ selected_variant.id }};

      const variants = this.getVariantJSON();
      this.currentVariant = variants.find(v => v.id === initialVariantId);
      if (!this.currentVariant || this.currentVariant.available !== true) {
        const firstAvailableVariant = variants.find(v => v.available);
        this.currentVariant = firstAvailableVariant || this.currentVariant;
      }
      if (!this.currentVariant) return;

      if (this.currentVariant.available === true && this.currentVariant.id !== initialVariantId) {
        this.updateURL();
      }

      this.currentVariant.options.forEach((value, index) => {
        const ul = this.querySelectorAll('.variant-values')[index];
        if (!ul) return;
        ul.querySelectorAll('.variant-value').forEach(li => {
          li.classList.toggle('active', li.dataset.value === value);
        });
      });

      this.updateFormID();
      this.updatePriceInstant();
      this.updateMedia();
      this.updateAddToCartButton();

      document.addEventListener('quantity:change', () => {
        this.updateAddToCartButton();
      });
    }

    onVariantClick(e) {
      const clickedLi = e.target.closest('.variant-value');
      if (!clickedLi) return;

      const parentUl = clickedLi.closest('.variant-values');
      parentUl.querySelectorAll('.variant-value').forEach(li =>
        li.classList.remove('active')
      );
      clickedLi.classList.add('active');

      this.getSelectedOptions();
      this.getSelectedVariant();
      if (!this.currentVariant) return;

      this.updateURL();
      this.updateFormID();
      this.updatePriceInstant();
      this.updateMedia();
      this.updateAddToCartButton();
    }

    getVariantJSON() {
      return (
        this.variantData ||
        (this.variantData = JSON.parse(
          this.querySelector('[type="application/json"]').textContent
        ))
      );
    }

    getSelectedOptions() {
      this.options = Array.from(this.querySelectorAll('.variant-values'))
        .map(ul => ul.querySelector('.variant-value.active')?.dataset.value)
        .filter(Boolean);
    }

    getSelectedVariant() {
      const variants = this.getVariantJSON();
      this.currentVariant = variants.find(v =>
        v.options.every((opt, i) => opt === this.options[i])
      );
    }

    updateURL() {
      window.history.replaceState(
        {},
        '',
        `${this.dataset.url}?variant=${this.currentVariant.id}`
      );
    }

    updateFormID() {
      const input = document.querySelector('#product-form input[name="id"]');
      if (input) input.value = this.currentVariant.id;
    }

    updatePriceInstant() {
      if (!this.currentVariant) return;

      const priceWrap = document.getElementById('price-{{ section.id }}');
      if (!priceWrap) return;

      const sellPriceEl = priceWrap.querySelector('.sell-price');
      const comparePriceEl = priceWrap.querySelector('.real-price');
      const unitPriceEl = priceWrap.querySelector('.sell-price-variant-perkg');
      const unitPriceWrap = unitPriceEl?.closest('.pd-bottom');
      const percentBadge = priceWrap.querySelector('[data-price-off-percent]');

      const price = this.currentVariant.price;
      const compare = this.currentVariant.compare_at_price;
      const currencySuffix = " {{ cart.currency.symbol }}";

      if (sellPriceEl) {
        let cleanPrice = formatMoneySafe(price).replace(/[^\d.,]/g, '').trim();
        sellPriceEl.textContent = cleanPrice + currencySuffix;
        sellPriceEl.classList.toggle('withoutbg', !(compare && compare > price));
      }

      if (comparePriceEl) {
        if (compare && compare > price) {
          let cleanCompare = formatMoneySafe(compare).replace(/[^\d.,]/g, '').trim();
          comparePriceEl.textContent = cleanCompare + currencySuffix;
          comparePriceEl.style.display = 'inline-block';
        } else {
          comparePriceEl.style.display = 'none';
        }
      }

      if (percentBadge) {
        if (compare && compare > price) {
          const saving = compare - price;
          const percentOff = Math.round((saving * 100) / compare);
          percentBadge.textContent = `-${percentOff}%`;
          percentBadge.style.display = 'inline-block';
        } else {
          percentBadge.style.display = 'none';
        }
      }

      if (unitPriceEl) {
        if (this.currentVariant.unit_price && this.currentVariant.unit_price_reference_unit) {
          const cleanUnitPrice = formatMoneySafe(this.currentVariant.unit_price).replace(/[^\d.,]/g, '').trim();
          unitPriceEl.textContent = `${cleanUnitPrice}${currencySuffix} / ${this.currentVariant.unit_price_reference_unit}`;
          unitPriceEl.style.display = '';
          if (unitPriceWrap) unitPriceWrap.style.display = '';
        } else {
          unitPriceEl.textContent = '';
          unitPriceEl.style.display = 'none';
          if (unitPriceWrap) unitPriceWrap.style.display = 'none';
        }
      }
    }

    updateMedia() {
      if (!this.currentVariant?.featured_media_id) return;

      const mediaId = this.currentVariant.featured_media_id;
      window.updateProductMediaById?.(mediaId);
      document.dispatchEvent(new CustomEvent('variant:media-change', {
        detail: { mediaId }
      }));
    }

    updateAddToCartButton() {
      window.themeStrings = {
        ...(window.themeStrings || {}),
        addToCart: "{{ 'products.product.add_to_cart' | t }}",
        addedToCart: "{{ 'products.product.added_to_cart' | t }}",
        soldOut: "{{ 'products.product.sold_out' | t }}"
      };

      const btn = document.getElementById('add-to-cart');
      const qtyInput = document.getElementById('Quantity');
      if (!btn || !qtyInput || !this.currentVariant) return;

      const label = btn.querySelector('.btn-label');
      const priceEl = btn.querySelector('.btn-price');
      const separatorEl = btn.querySelector('.btn-separator');

      if (!this.currentVariant.available) {
        btn.classList.remove('loading', 'success');
        btn.disabled = true;
        btn.classList.add('out-of-stock');

        if (label) label.textContent = window.themeStrings.soldOut;
        if (priceEl) priceEl.textContent = '';
        if (separatorEl) separatorEl.style.display = 'none';

        return;
      }

      btn.classList.remove('out-of-stock');
      btn.disabled = false;

      const qty = parseInt(qtyInput.value, 10) || 1;
      const total = this.currentVariant.price * qty;

      if (label) label.textContent = window.themeStrings.addToCart;
      if (separatorEl) separatorEl.style.display = '';

      if (priceEl) {
        const currencySuffix = " {{ cart.currency.symbol }}";
        let cleanTotal = formatMoneySafe(total).replace(/[^\d.,]/g, '').trim();
        priceEl.textContent = cleanTotal + currencySuffix;
      }
    }
  }

  customElements.define('variant-selector', VariantSelector);
  </script>

  <script>
  /* ======================================================
     URL FALLBACK (KEEP YOUR EXISTING BEHAVIOR)
  ====================================================== */
  document.addEventListener('DOMContentLoaded', () => {
    const hasVariant = new URLSearchParams(window.location.search).has('variant');
    const defaultVariantId = {{ default_variant.id }};

    if (!hasVariant) {
      const url = new URL(window.location.href);
      url.searchParams.set('variant', defaultVariantId);
      window.history.replaceState({}, '', url.toString());
    }
  });
  </script>

  <script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.box-content-in').forEach((slider) => {
      let isDragging = false;
      let startX = 0;
      let scrollLeft = 0;
      let dragMoved = false;

      const stopDragging = () => {
        isDragging = false;
        slider.classList.remove('dragging');
        document.body.classList.remove('box-dragging');
      };

      const onPointerMove = (event) => {
        if (!isDragging) return;

        const delta = event.clientX - startX;
        if (Math.abs(delta) > 3) {
          dragMoved = true;
        }

        event.preventDefault();
        slider.scrollLeft = scrollLeft - delta;
      };

      const onPointerUp = () => {
        stopDragging();
        window.removeEventListener('pointermove', onPointerMove);
        window.removeEventListener('pointerup', onPointerUp);
        window.removeEventListener('pointercancel', onPointerUp);
      };

      slider.addEventListener('pointerdown', (event) => {
        if (event.pointerType === 'mouse' && event.button !== 0) return;

        isDragging = true;
        dragMoved = false;
        startX = event.clientX;
        scrollLeft = slider.scrollLeft;
        slider.classList.add('dragging');
        document.body.classList.add('box-dragging');

        window.addEventListener('pointermove', onPointerMove, { passive: false });
        window.addEventListener('pointerup', onPointerUp);
        window.addEventListener('pointercancel', onPointerUp);
      });

      slider.addEventListener('click', (event) => {
        if (!dragMoved) return;
        event.preventDefault();
        event.stopPropagation();
        dragMoved = false;
      }, true);
    });
  });
  </script>

  <script>
      $(document).ready(function () {
    const $mainSlider = $('.prod-main-image');
    const $galleryWrap = $('.pro-right-side');
    const $prevArrow = $galleryWrap.find('.custom-prev');
    const $nextArrow = $galleryWrap.find('.custom-next');
    const galleryTransitionSpeed = 180;
    const updateGalleryCounter = (event, slick, currentSlide) => {
      const counter = document.querySelector('.product-gallery-counter');
      if (!counter || !slick) return;

      const currentEl = counter.querySelector('[data-gallery-current]');
      const totalEl = counter.querySelector('[data-gallery-total]');
      const currentIndex = typeof currentSlide === 'number' ? currentSlide : slick.currentSlide || 0;

      if (currentEl) currentEl.textContent = currentIndex + 1;
      if (totalEl) totalEl.textContent = slick.slideCount;
    };

    const updateGalleryArrowState = (event, slick, currentSlide) => {
      if (!slick) return;

      const currentIndex = typeof currentSlide === 'number' ? currentSlide : slick.currentSlide || 0;
      const lastIndex = Math.max((slick.slideCount || 1) - 1, 0);
      const atStart = currentIndex <= 0;
      const atEnd = currentIndex >= lastIndex;

      $prevArrow
        .toggleClass('disabled', atStart)
        .prop('disabled', atStart)
        .attr('aria-disabled', atStart ? 'true' : 'false');

      $nextArrow
        .toggleClass('disabled', atEnd)
        .prop('disabled', atEnd)
        .attr('aria-disabled', atEnd ? 'true' : 'false');
    };

    $mainSlider.on('init reInit afterChange', (event, slick, currentSlide) => {
      updateGalleryCounter(event, slick, currentSlide);
      updateGalleryArrowState(event, slick, currentSlide);
    });

    $mainSlider.slick({
      slidesToShow: 1,
      slidesToScroll: 1,
      arrows: false,
      fade: true,
      speed: galleryTransitionSpeed,
      cssEase: 'ease-out',
      draggable: true,
      swipe: true,
      touchMove: true,
      touchThreshold: 8,
      infinite: false,
      asNavFor: '.prod-thumb-image',
    });
    $('.prod-thumb-image').slick({
      slidesToShow: 4,
      slidesToScroll: 1,
      asNavFor: '.prod-main-image',
      focusOnSelect: true,
      centerMode: false,
      vertical: true,
      verticalSwiping: true,
      draggable: true,
      swipe: true,
      touchMove: true,
      swipeToSlide: true,
      infinite: false,
      arrows: false,
      responsive: [
        {
          breakpoint: 768,
          settings: {
            vertical: false,
            verticalSwiping: false,
            slidesToShow: 5,
            focusOnSelect: true,
            centerMode: false,
          }
        }
      ]
    });

    $prevArrow.click(function () {
      if ($(this).hasClass('disabled')) return;
      $mainSlider.slick('slickPrev');
    });
    $nextArrow.click(function () {
      if ($(this).hasClass('disabled')) return;
      $mainSlider.slick('slickNext');
    });

    const goToVariantMedia = (mediaId) => {
      if (!mediaId) return;

      const mainSlider = document.querySelector('.prod-main-image');
      if (!mainSlider) return;

      if (!$mainSlider.hasClass('slick-initialized')) return;

      const targetSlide = mainSlider.querySelector(`.slick-slide[data-media-id="${mediaId}"]`);
      if (!targetSlide) return;

      const slideIndex = Number(targetSlide.getAttribute('data-slick-index'));
      if (Number.isNaN(slideIndex) || slideIndex < 0) return;

      $mainSlider.slick('slickGoTo', slideIndex);
    };

    window.updateProductMediaById = goToVariantMedia;
    document.addEventListener('variant:media-change', (event) => {
      goToVariantMedia(event.detail?.mediaId);
    });

    const initialVariantSelector = document.querySelector('variant-selector');
    if (initialVariantSelector?.currentVariant?.featured_media_id) {
      goToVariantMedia(initialVariantSelector.currentVariant.featured_media_id);
    }
      });

    Fancybox.bind("[data-fancybox='gallery-box']", {
      Hash: false,
      Thumbs: {
        autoStart: false,
      },
    });
  </script>

  <script>
    $(document).ready(function(){
      $(document).on('click', '.product-accordion .pa-ques-wrap', function() {
        const $clickedItem = $(this).closest('.pa-item');
        const $clickedAnswer = $clickedItem.children('.pa-div');

        if ($clickedItem.hasClass('active')) {
          $clickedItem.removeClass('active');
          $clickedAnswer.stop(true, true).slideUp(300);
          return;
        }

        $clickedItem.addClass('active');
        $clickedAnswer.stop(true, true).slideDown(300);
      });
    });

  </script>

  <script>
    document.addEventListener('click', function (e) {
      const btn = e.target.closest('.offer-copy-btn');
      if (!btn) return;

      navigator.clipboard.writeText(btn.dataset.code).then(() => {
        btn.textContent = 'Copied';
        btn.classList.add('copied');

        setTimeout(() => {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 2000);
      });
    });
  </script>

