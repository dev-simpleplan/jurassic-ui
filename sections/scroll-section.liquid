<section class="scroll-sec">
    <div class="scroll-nav">
        <button class="scroll-arrow prev" aria-label="Scroll Left">{% render 'arrow-prev' %}</button>
        <button class="scroll-arrow next" aria-label="Scroll Right">{% render 'arrow-next' %}</button>
    </div>
    <div class="scrollsec-wrapper">
        {% for block in section.blocks %}
            {% if block.type == 'slide1' %}
                <div class="scrollsec-slide slide_1">
                    <div class="scrollsecslide-in">
                        <div class="container-fluid">
                            <div class="slide1-wrap">
                                <div class="sw-first-left">
                                    <h2>{{section.settings.section_heading}}</h2>
                                    <p>{{section.settings.section_subheading}}</p>
                                </div>
                                <div class="sw-first-right">
                                    <div class="swfr-in">
                                        <div class="swright-top">
                                            <div class="swrt-image">
                                                <img src="{{ block.settings.main_image |  img_url: 'master' }}" alt="">
                                                <div class="swrt-scroll">
                                                    <img src="{{ block.settings.scroll_image |  img_url: 'master' }}" alt="">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="swright-bottom">
                                            <h3>{{ block.settings.side_heading }}</h3>
                                            <p class="small">{{ block.settings.side_content }}​​</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% elsif block.type == 'slide2' %}
                <div class="scrollsec-slide slide_2">
                    <div class="scrollsecslide-in">
                        <div class="container-fluid">
                            <div class="slide2-wrap">
                                <div class="sw-second-left">
                                    <div class="sws-image">
                                        <img src="{{ block.settings.main_image |  img_url: 'master' }}" alt="">
                                    </div>
                                    <div class="sws-content">
                                        <p>{{ block.settings.image_label }}</p>
                                    </div>
                                </div>
                                <div class="sw-second-right">
                                    <div class="sws-heading">
                                        <h3>{{ block.settings.side_heading }}</h3>
                                        <p class="small">{{ block.settings.side_content }}</p>
                                    </div>
                                    <div class="sws-fruits">
                                        <div class="swsfruits-item fruit1">
                                            <img src="{{ block.settings.fruit1 | img_url: 'master' }}" alt="">
                                        </div>
                                        <div class="swsfruits-item fruit2">
                                            <img src="{{ block.settings.fruit2 | img_url: 'master' }}" alt="">
                                        </div>
                                        <div class="swsfruits-item fruit3">
                                            <img src="{{ block.settings.fruit3 | img_url: 'master' }}" alt="">
                                        </div>
                                        <div class="swsfruits-item fruit4">
                                            <img src="{{ block.settings.fruit4 | img_url: 'master' }}" alt="">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% elsif block.type == 'slide3' %}
                <div class="scrollsec-slide slide_3">
                    <div class="scrollsecslide-in">
                        <div class="container-fluid">
                            <div class="slide3-wrap">
                                <div class="sw-three-left">
                                    <div class="swfr-in">
                                        <div class="swright-top">
                                            <div class="sidetop-text">{{ block.settings.image_label }}</div>
                                            <div class="swrt-image">
                                                <img src="{{ block.settings.side_image |  img_url: 'master' }}" alt="">
                                                <div class="swrt-scroll">
                                                    <img src="{{ block.settings.scroll_image |  img_url: 'master' }}" alt="">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="swright-bottom">
                                            <h3>{{ block.settings.side_heading }}</h3>
                                            <p class="small">{{ block.settings.side_content }}</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="sw-three-right sw-second-left">
                                    <div class="sws-image">
                                        <img src="{{ block.settings.main_image |  img_url: 'master' }}" alt="">
                                    </div>
                                    <div class="sws-content">
                                        <p>{{ block.settings.main_image_label }}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% elsif block.type == 'slide4' %}
                <div class="scrollsec-slide slide_4">
                    <div class="scrollsecslide-in">
                        <div class="container-fluid">
                            <div class="slide4-wrap">
                                <div class="sw-four-left">
                                    <div class="sws-heading">
                                        <h3>{{ block.settings.left_heading }}</h3>
                                        <p class="small">{{ block.settings.left_content }}</p>
                                    </div>
                                </div>
                                <div class="sw-four-right">
                                    <div class="swfr-in">
                                        <div class="swright-top">
                                            <div class="sidetop-text">{{ block.settings.side_image_label }}</div>
                                            <div class="swrt-image">
                                                <img src="{{ block.settings.main_image |  img_url: 'master' }}" alt="">
                                            </div>
                                        </div>
                                        <div class="swright-bottom">
                                            <h3>{{ block.settings.side_heading }}</h3>
                                            <p class="small">{{ block.settings.side_content }}</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}
        {% endfor %}
