                                <div class="scs-item">
                                    <div class="scs-in">
                                        <div class="scs-top">
                                            <div class="scs-image">
                                                <img src="{{ block.settings.main_image |  img_url:'master' }}" alt="">
                                            </div>
                                        </div>
                                        <div class="scs-bottom">
                                            <div class="swsb-heading">
                                                <h4>{{ block.settings.side_heading }}</h4>
                                            </div>
                                            <div class="swsb-para">
                                                <p>{{ block.settings.side_content }}</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% elsif block.type == 'slide2' %}
                            <div class="item">
                                <div class="scs-item">
                                    <div class="scs-in">
                                        <div class="scs-top">
                                            <div class="scs-image">
                                                <img src="{{ block.settings.main_image |  img_url:'master' }}" alt="">
                                            </div>
                                            <div class="scs-image-label">
                                                <p>{{ block.settings.image_label }}</p>
                                            </div>
                                        </div>
                                        <div class="scs-bottom">
                                            <div class="swsb-heading">
                                                <h4>{{ block.settings.side_heading }}</h4>
                                            </div>
                                            <div class="swsb-para">
                                                <p>{{ block.settings.side_content }}</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% elsif block.type == 'slide3' %}
                            <div class="item">
                                <div class="scs-item">
                                    <div class="scs-in">
                                        <div class="scs-top">
                                            <div class="scs-image">
                                                <img src="{{ block.settings.side_image |  img_url:'master' }}" alt="">
                                            </div>
                                            <div class="scs-image-label">
                                                <p>{{ block.settings.image_label }}</p>
                                            </div>
                                        </div>
                                        <div class="scs-bottom">
                                            <div class="swsb-heading">
                                                <h4>{{ block.settings.side_heading }}</h4>
                                            </div>
                                            <div class="swsb-para">
                                                <p>{{ block.settings.side_content }}</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="item">
                                <div class="scs-item">
                                    <div class="scs-in">
                                        <div class="scs-top">
                                            <div class="scs-image">
                                                <img src="{{ block.settings.main_image |  img_url:'master' }}" alt="">
                                            </div>
                                            <div class="scs-image-label">
                                                <p>{{ block.settings.main_image_label }}</p>
                                            </div>
                                        </div>
                                        <div class="scs-bottom">
                                            <div class="swsb-heading">
                                                <h4>{{ block.settings.image_heading }}</h4>
                                            </div>
                                            <div class="swsb-para">
                                                <p>{{ block.settings.image_content }}</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% elsif block.type == 'slide4' %}
                            <div class="item">
                                <div class="scs-item">
                                    <div class="scs-in">
                                        <div class="scs-top">
                                            <div class="scs-image">
                                                <img src="{{ block.settings.main_image |  img_url:'master' }}" alt="">
                                            </div>
                                            <div class="scs-image-label">
                                                <p>{{ block.settings.side_image_label }}</p>
                                            </div>
                                        </div>
                                        <div class="scs-bottom">
                                            <div class="swsb-heading">
                                                <h4>{{ block.settings.side_heading }}</h4>
                                            </div>
                                            <div class="swsb-para">
                                                <p>{{ block.settings.side_content }}</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>
<div class="custom-scrollbar-track">
    <div class="custom-scrollbar-thumb"></div>
</div>
<style>
    .scrollsec-wrapper {
    scrollbar-width: none;
    -ms-overflow-style: none;
}
.scrollsec-wrapper::-webkit-scrollbar {
    display: none;
}
.custom-scrollbar-track {
    width: 80%;
    height: 4px;
    background: #e0e0e0;
    border-radius: 2px;
    margin: 0 auto;
    margin-top: 20px;
    position: relative;
    cursor: pointer;
}
.custom-scrollbar-thumb {
    height: 100%;
    background: #1a1a1a;
    border-radius: 2px;
    position: absolute;
    left: 0;
    top: 0;
    cursor: grab;
}
@media screen and (max-width: 991px) {
    .custom-scrollbar-track{
        display: none;
    }
}
</style>
