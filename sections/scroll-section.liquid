    const prevBtn = document.querySelector('.scroll-arrow.prev');

    if (!wrapper || !nextBtn || !prevBtn) return;

    nextBtn.addEventListener('click', () => {
        // Calculate the width of one slide
        const slideWidth = wrapper.querySelector('.scrollsec-slide').offsetWidth;
        wrapper.scrollBy({ left: slideWidth, behavior: 'smooth' });
