<script>
  // Define the function globally so your cart script can "see" it
  window.refreshShippingPrices = function() {
    try {
      const shippingPrices = {
        {%- for rate in shop.metaobjects.shipping_rate.values -%}
          "{{ rate.market_code.value | downcase | strip }}": "{{ rate.price_value.value | strip }}",
        {%- endfor -%}
        "default": "{{ shop.metafields.custom.default_shipping.value | default: '$19' }}"
      };

      const market = window.corner?.sessionData?.market;
      if (!market) return;
      
      const marketKey = market.toLowerCase();
      const shippingPrice = shippingPrices[marketKey] || shippingPrices['default'];

      const mainEl = document.getElementById('corner-cowi-cart-custom-html-above-cta');
      const deliveryEl = document.getElementById('delivery-data');

      if (mainEl) mainEl.innerText = `Shipping starts from ${shippingPrice}.\n Final prices will be calculated at checkout.`;
      if (deliveryEl) deliveryEl.innerText = `Free shipping from ${shippingPrice}.`;
      
    } catch (e) {
      console.log("Shipping price update skipped.");
    }
  };

  // Run once when page is ready
  document.addEventListener("DOMContentLoaded", window.refreshShippingPrices);
  document.addEventListener("corner:ready", window.refreshShippingPrices);
</script>