<script>
  (function() {
    {% assign suffix = cart.currency.symbol %}
    const shippingPrices = {
      {%- for rate in shop.metaobjects.shipping_rate.values -%}
        {%- if rate.market_code != blank and rate.price_value != blank -%}
          {% assign clean_price = rate.price_value | replace: '$', '' | replace: 'Rs.', '' | replace: '€', '' | strip %}
          "{{ rate.market_code | downcase | strip }}": "{{ clean_price }} {{ suffix }}",
        {%- endif -%}
      {%- endfor -%}
      {% assign default_raw = shop.metafields.custom.default_shipping.value | default: '19' %}
      {% assign clean_default = default_raw | replace: '$', '' | replace: 'Rs.', '' | replace: '€', '' | strip %}
      "default": "{{ clean_default }} {{ suffix }}"
    };

    let lastMarketKey = null;

    function resolveMarketKey() {
      const urlParams = new URLSearchParams(window.location.search);
      let market = window.corner?.sessionData?.market || urlParams.get('country') || 'default';
      let marketKey = String(market).toLowerCase().trim();

      const countryMap = {
        france: 'fr',
        germany: 'de',
        austria: 'at',
        'united kingdom': 'gb',
        'united states': 'us',
        india: 'in'
      };

      if (countryMap[marketKey]) marketKey = countryMap[marketKey];
      return marketKey;
    }

    function updateShippingText(force) {
      const mainEl = document.getElementById('corner-cowi-cart-custom-html-above-cta');
      const deliveryEl = document.getElementById('delivery-data');
      const newOuterPrice = document.getElementById('delivery-data-new');
      if (!mainEl && !deliveryEl && !newOuterPrice) return;

      try {
        const marketKey = resolveMarketKey();

        if (!force && marketKey === lastMarketKey) {
          return;
        }

        lastMarketKey = marketKey;
        const shippingPrice = shippingPrices[marketKey] || shippingPrices.default;

        if (mainEl) {
          const text = `Shipping starts from ${shippingPrice}.\n Final prices will be calculated at checkout.`;
          if (mainEl.innerText !== text) mainEl.innerText = text;
        }

        if (deliveryEl) {
          const text = `Free shipping from ${shippingPrice}.`;
          if (deliveryEl.innerText !== text) deliveryEl.innerText = text;
        }

        if (newOuterPrice) {
          const text = `Free shipping from ${shippingPrice}.`;
          if (newOuterPrice.innerText !== text) newOuterPrice.innerText = text;
        }

      } catch (e) {
        console.error('Shipping Script Error:', e);
      }
    }

    function scheduleUpdate(force) {
      window.requestAnimationFrame(() => updateShippingText(force));
    }

    function bootShippingUpdates() {
      scheduleUpdate(true);

      let attempts = 0;
      const retryTimer = window.setInterval(() => {
        attempts += 1;
        scheduleUpdate(false);

        if (
          window.corner?.sessionData?.market ||
          attempts >= 5
        ) {
          window.clearInterval(retryTimer);
        }
      }, 700);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootShippingUpdates, { once: true });
    } else {
      bootShippingUpdates();
    }

    window.addEventListener('load', () => scheduleUpdate(false), { once: true });
  })();
</script>
