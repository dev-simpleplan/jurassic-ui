{% assign default_variant = nil %}

{% for variant in product.variants %}
  {% if variant.metafields.custom.is_prior == true and variant.available %}
    {% assign default_variant = variant %}
    {% break %}
  {% endif %}
{% endfor %}

{% if default_variant == nil %}
  {% for variant in product.variants %}
    {% if variant.available %}
      {% assign default_variant = variant %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if default_variant == nil %}
  {% assign default_variant = product.variants.first %}
{% endif %}

<div class="product-card-primary">
  <div class="fruits_card">
      <div class="fc_top">
        <a href="{{ product.url }}" class="card-link"></a>
        {% assign images = product.images %}

        <div class="fc_image {% if images.size > 1 %}has-hover-img{% endif %}">
          {% if images.size > 0 %}
            <img
              src="{{ images.first | img_url: 'master' }}"
              alt="{{ product.title | escape }}"
              class="img_sizing primary-img">

            {% if images.size > 1 %}
              <img
                src="{{ images[1] | img_url: 'master' }}"
                alt="{{ product.title | escape }}"
                class="img_sizing hover-img">
            {% endif %}
          {% else %}
            <img
              src="https://cdn.shopify.com/s/files/1/0752/8015/4881/files/jf-placeholder.png?v=1769522647"
              alt="No Image Available"
              class="img_sizing primary-img">
          {% endif %}
        </div>

        {% assign product_tags = product.tags | downcase %}
        {% if product.tags.size > 0 or product.metafields.custom.certificate or product.metafields.custom.quality_label != blank %}
          <div class="fc_category_tags">
            {% if product.metafields.custom.certificate %}
              {% assign certificate = product.metafields.custom.certificate.value %}
              {% for item in product.metafields.custom.certificate.value %}
                <div class="fc_organic_auth">
                  <img
                    src="{{ item.badge_image | img_url:'master' }}"
                  alt="{{ item.display_name }}"
                  class="img_sizing">
                </div>
              {% endfor %}
            {% endif %}

            {% if product.metafields.custom.quality_label != blank %}
              <span>{{ product.metafields.custom.quality_label.value | default: product.metafields.custom.quality_label }}</span>
            {% endif %}

            {% comment %}
              {% for tag in product.tags %}
                {% unless tag == 'Best Seller' %}
                  <span>{{ tag }}</span>
                {% endunless %}
              {% endfor %}
            {% endcomment %}
          </div>
        {% endif %}

        {% assign is_bestseller_product = false %}
        {% if product.tags contains 'Best Seller' %}
          {% assign is_bestseller_product = true %}
        {% endif %}
        <div
          class="fc_bestsell_tags{% unless is_bestseller_product %} red{% endunless %}"
          data-card-top-badge
          data-is-bestseller="{% if is_bestseller_product %}true{% else %}false{% endif %}"
          style="{% unless is_bestseller_product or default_variant.compare_at_price > default_variant.price %}display:none;{% endunless %}">
          <span data-card-top-badge-text>
            {% if is_bestseller_product %}
              Bestseller
            {% elsif default_variant.compare_at_price > default_variant.price %}
              -{{ default_variant.compare_at_price | minus: default_variant.price | times: 100 | divided_by: default_variant.compare_at_price | round }}%
            {% endif %}
          </span>
        </div>
      </div>

    <div class="fc_bottom_outer">
      <div class="fc_bottom">

        <div class="fc_bottom_top">
          <div class="star_review">
            <div class="star_rating">
              <p data-oke-star-rating data-oke-reviews-product-id="shopify-{{ product.id }}"></p>
            </div>
            <div class="rating_info">
              <span class="dot_seperator dynamic-review-dot"></span>
              {% if product.metafields.custom.country_of_origin.value.country_name %}
                <p>{{ 'products.product.from' | t }} {{ product.metafields.custom.country_of_origin.value.country_name }}</p>
              {% endif %}
            </div>
          </div>
          <p class="fc_product_title">
            <a href="{{ product.url }}">{{ product.title | truncate: 50 }}</a>
          </p>
        </div>

        <div class="fc_bottom_bottom">
          <div class="fc_bottom_center">
            <div class="fc_variant_outer">
              <div class="fc_variant_wrap">
                <div class="wrapper-dropdown" id="dropdown-{{ product.id }}">
                  <span class="selected-display">
                    <b>{{ default_variant.title }} </b>
                    {% comment %} {% if default_variant.metafields.custom.pieces %}({{ default_variant.metafields.custom.pieces }}){% endif %}
                    — {{ default_variant.price | money }} {% endcomment %}
                  </span>
                  
                  <ul class="dropdown" data-lenis-prevent>
                    {% for variant in product.variants %}
                      <li 
                        class="dropdown-item"
                        data-id="{{ variant.id }}"
                        data-selected-title="{{ variant.title | escape }}"
                        data-price="{{ variant.price | money_without_currency }} {{ cart.currency.symbol }}"
                        data-compare="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money_without_currency }} {{ cart.currency.symbol }}{% endif %}"
                        data-unit="{% if variant.unit_price_measurement %}{{ variant.unit_price | money_without_currency }} {{ cart.currency.symbol }} / {{ variant.unit_price_measurement.reference_unit }}{% endif %}"
                        data-inventory="{{ variant.inventory_quantity }}"
                      >
                        <a href="javascript:void(0)">
                          {% if variant.metafields.custom.bestseller == true %}
                              <div class="vv-bestseller">best seller</div>
                            {% endif %}
                          <div class="item-details">
                            <span class="item-title">
                              {{ variant.title }} 
                            </span>
                            {% if variant.metafields.custom.pieces %}
                                <span class="item-pieces">( {{ variant.metafields.custom.pieces }} )</span>
                              {% endif %}
                          </div>
                          <span class="pull-right">
                            {{ variant.price | money }}
                            {% if variant.unit_price_measurement %}
                              <span class="item-unit-price">{{ variant.unit_price | money }} / {{ variant.unit_price_measurement.reference_unit }}</span>
                            {% endif %}
                          </span>
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                  <input type="hidden" name="id" value="{{ default_variant.id }}" class="custom-variant-id">
                </div>
              </div>
              <div class="selected_variant_dropdown" data-lenis-prevent></div>
            </div>
          </div>

          <div class="fc_bottom_end">
            <div class="fc_price_weight">
              {% assign current_variant = nil %}
              {% assign current_variant = default_variant %}

              <div class="flex-row">
                <p>
                  {% comment %} The selling price always exists {% endcomment %}
                  <span class="selling_price {% unless current_variant.compare_at_price > current_variant.price %}withoutbg{% endunless %}">
                    {{ current_variant.price | money_without_currency }} {{ cart.currency.symbol }}
                  </span>

                  {% comment %} 
                    CRITICAL: Always render the strike tag so JS can find it. 
                    Use inline CSS to hide it if there is no initial discount.
                  {% endcomment %}
                  <strike id="compare_price" style="{% unless current_variant.compare_at_price > current_variant.price %}display:none;{% endunless %}">
                    {% if current_variant.compare_at_price > current_variant.price %}
                      {{ current_variant.compare_at_price | money_without_currency }} {{ cart.currency.symbol }}
                    {% endif %}
                  </strike>
                </p>

                <span class="off-percent-badge" data-card-off-percent style="{% unless current_variant.compare_at_price > current_variant.price %}display:none;{% endunless %}">
                  {% if current_variant.compare_at_price > current_variant.price %}
                    -{{ current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price | round }}%
                  {% endif %}
                </span>
              </div>

              <p class="fc_weight">
                {% if current_variant.unit_price_measurement %}
                  {{ current_variant.unit_price | money_without_currency }} {{ cart.currency.symbol }} / {{ current_variant.unit_price_measurement.reference_unit }}
                {% else %}
                  {{ current_variant.price | money_without_currency }} {{ cart.currency.symbol }} / unit
                {% endif %}
              </p>


            </div>
            <div class="fc_add_to_cart_outer">
              <form action="/cart/add" method="post" enctype="multipart/form-data" class="product-card-add-form">
                <input type="hidden" name="id" value="{{ current_variant.id }}">
                <input type="hidden" name="quantity" value="1">

                <div class="fc_add_to_cart"
                  data-variant-id="{{ current_variant.id }}"
                  data-available="{{ current_variant.available }}"
                  data-inventory="{{ current_variant.inventory_quantity }}">

                  <button
                    type="submit"
                    class="add-to-cart-btn"
                    {% unless current_variant.available %}disabled{% endunless %}>
                    {% if current_variant.available %}
                      {{ 'products.product.add_to_cart' | t }}
                    {% else %}
                      {{ 'products.product.sold_out' | t }}
                    {% endif %}
                  </button>
                  {% comment %} {% unless product.available %}
                    <button class="open-my-form BIS_trigger">
                      Email when available
                    </button>
                  {% endunless %} {% endcomment %}
                </div>
              </form>
            </div>
            <div class="fc_trust_text">
              <p class="{% if current_variant.available and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity < 100 %}low-stock{% endif %}">
                {% if current_variant.available == false or current_variant.inventory_quantity <= 0 %}
                  {{ 'products.product.out_of_stock' | t }}
                {% elsif current_variant.inventory_quantity < 100 %}
                  {{ 'products.product.inventory_status' | t: count: current_variant.inventory_quantity }}
                {% else %}
                  {{ 'products.product.in_stock' | t }}
                {% endif %}
              </p>
              {% comment %} <span class="dot_seperator"></span>
              <p>Ships in 24 hrs</p> {% endcomment %}
              
              {% comment %} <p>{{ product.metafields.custom.benefit | default: 'Product Benefit' }}</p> {% endcomment %}
               {%- capture benefit_text -%}
                {%- if product.tags contains 'Fresh fruit' -%}
                  {{ 'benefits.freshly_picked' | t }}
                {%- elsif product.tags contains 'New' -%}
                  {{ 'benefits.rare_handpicked' | t }}
                {%- elsif product.tags contains 'Dried Fruit' or product.tags contains 'Date' -%}
                  {{ 'benefits.pure_raw' | t }}
                {%- elsif product.tags contains 'Fine food' or product.tags contains 'Honey' -%}
                  {{ 'benefits.artisanal' | t }}
                {%- else -%}
                  {{ product.metafields.custom.benefit }}
                {%- endif -%}
              {%- endcapture -%}

              {%- assign benefit_text = benefit_text | strip -%}

              {%- if benefit_text != blank -%}
                <span class="dot_seperator"></span>
                <p>{{ benefit_text }}</p>
              {%- endif -%}

              {%- assign benefit_text = benefit_text | strip -%}

              {%- if benefit_text != blank -%}
                <span class="dot_seperator"></span>
                <p>{{ benefit_text }}</p>
              {%- endif -%}
            </div>
          </div>
        </div>


      </div>
    </div>
  </div>
</div>

{% comment %} <script>
document.addEventListener('DOMContentLoaded', () => {

  async function addToCart(id, qty = 1) {
    return fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, quantity: qty })
    }).then(r => r.json());
  }

  function openSideCartDirectly() {
    const sideCart = document.querySelector('.sideCart');
    if (!sideCart) return;

    sideCart.classList.add('active');
    document.body.classList.add('stay');
    document.documentElement.classList.add('stay');

    // 🔑 ENSURE CONTENT IS RENDERED
    // 🔑 Call the correct function from your side cart script
    if (typeof window.loadCartItems === 'function') {
      window.loadCartItems();
    }
  }


  async function updateHeaderCartCount() {
    const cart = await fetch('/cart.js').then(r => r.json());
    const el = document.querySelector('.header__cart-quantity');
    if (!el) return;
    el.textContent = cart.item_count;
    el.classList.toggle('is-hidden', cart.item_count === 0);
  }

  /* ---------------- VARIANT SWITCH ---------------- */
  document.querySelectorAll('.fc_variant_item').forEach(variant => {
    variant.addEventListener('click', () => {
      const card = variant.closest('.product-card-primary');
      if (!card) return;

      // active state
      variant
        .parentElement
        .querySelectorAll('.fc_variant_item')
        .forEach(v => v.classList.remove('active'));

      variant.classList.add('active');

      const variantId = variant.dataset.id;
      const price = variant.dataset.price;
      const compare = variant.dataset.compare;
      const unit = variant.dataset.unit;
      {% comment %} const image = variant.dataset.image; {% endcomment %}

      // update price
      const priceWrap = card.querySelector('.fc_price_weight');
      if (priceWrap) {
        priceWrap.querySelector('.selling_price').innerText = price;
        const compareEl = priceWrap.querySelector('#compare_price');
        if (compareEl) compareEl.innerText = compare;
      }

      // update image
      {% comment %} const img = card.querySelector('.primary-img');
      if (img && image) img.src = image; {% endcomment %}

      // update add to cart button variant
      const addWrap = card.querySelector('.fc_add_to_cart');
      if (addWrap) {
        addWrap.dataset.variantId = variantId;
      }
    });
  });

  /* ---------------- ADD TO CART ---------------- */
  document.querySelectorAll('.fc_add_to_cart .add-to-cart-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopImmediatePropagation();
      const wrap = btn.closest('.fc_add_to_cart');
      if (!wrap) return;

      const variantId = Number(wrap.dataset.variantId);
      if (!variantId) return;

      btn.disabled = true;
      btn.textContent = 'Adding…';

      try {
        await addToCart(variantId, 1);
        openSideCartDirectly();

        // This is redundant if you fixed the function above, 
        // but it's good practice to call the refresh logic here.
        if (typeof window.loadCartItems === 'function') {
          await window.loadCartItems();
        }

      } catch (err) {
        console.error('Add to cart failed', err);
      } finally {
        btn.disabled = false;
        btn.textContent = 'Add to Cart';
      }
    });
  });

});
</script> {% endcomment %}
<script>
  document.querySelectorAll('.fc_add_to_cart').forEach(function(el) {
  const btn = el.querySelector('button');
  
  if (btn && btn.disabled) {
    el.classList.add('out-of-stock');
  }
});
</script>
