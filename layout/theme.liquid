      <style>
        .homepage-loader {
          position: fixed;
          inset: 0;
          z-index: 2147483647;
          display: flex;
          align-items: center;
          justify-content: center;
          background: #000;
          opacity: 0;
          visibility: hidden;
          transition: opacity 0.45s ease, visibility 0.45s ease;
          pointer-events: none;
        }

        .homepage-loader__media {
          width: min(76vw, 520px);
          max-width: 520px;
        }

        .homepage-loader__media img {
          display: block;
          width: 100%;
          height: auto;
        }

        html.show-home-loader .homepage-loader {
          opacity: 1;
          visibility: visible;
          pointer-events: auto;
        }

        html.show-home-loader,
        html.show-home-loader body {
          overflow: hidden;
          height: 100%;
          overscroll-behavior: none;
        }

        html.show-home-loader body {
          position: fixed;
          width: 100%;
          inset: 0;
          touch-action: none;
        }

        html.home-loader-done .homepage-loader {
          opacity: 0;
          visibility: hidden;
          pointer-events: none;
        }
      </style>
