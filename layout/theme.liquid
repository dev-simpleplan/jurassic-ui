        <script>
          document.addEventListener("DOMContentLoaded", (event) => {
            // 1. Initialize Lenis
            window.lenis = new Lenis({
              duration: 1.2,
              easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t))
            });

            function raf(time) {
              window.lenis.raf(time);
              requestAnimationFrame(raf);
            }
            requestAnimationFrame(raf);

            // 2. Setup Header Logic
            const header = document.querySelector('header');
            let lastScroll = 0;
            const BACKDROP_TRIGGER = 80;

            window.lenis.on('scroll', ({ scroll }) => {
              if (scroll > BACKDROP_TRIGGER) {
                header.classList.add('backdrop');
              } else {
                header.classList.remove('backdrop');
              }

              if (scroll > BACKDROP_TRIGGER) {
                header.classList.add('active');
              } else {
                header.classList.remove('active');
              }
              lastScroll = scroll;
            });

            // 3. THE UNIVERSAL FIX (Inside the same scope)
            // This watches for height changes from Okendo, Instafeed, etc.
            const scrollTarget = document.querySelector('.main');
            if (scrollTarget) {
              const resizeObserver = new ResizeObserver(() => {
                window.lenis.resize();
                if (window.ScrollTrigger) {
                  window.ScrollTrigger.refresh();
                }
              });
              resizeObserver.observe(scrollTarget);
              resizeObserver.observe(document.body);
            }

            // 4. Initial Safety Refresh
            let refreshCount = 0;
            const refreshInterval = setInterval(() => {
              window.lenis.resize();
              refreshCount++;
              if (refreshCount >= 5) clearInterval(refreshInterval);
            }, 1000);

            // --- GSAP Logic Starts ---
            if (window.gsap && window.ScrollTrigger) {
  gsap.registerPlugin(ScrollTrigger);
  const mm = gsap.matchMedia();

  mm.add("(min-width: 993px)", () => {
    const imageText = document.querySelector(".image-text-scroll");
    if (!imageText) return;

    // 1. ONLY hide the items that should appear LATER
    // We leave #image1 and .dt-in.one visible by default
    gsap.set(
      ["#image3", ".dt-in.three", "#image2", ".dt-in.two", ".dt-in.four"],
      { opacity: 0 }
    );

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: imageText,
        start: "top top",
        end: "+=200%", 
        pin: true,
        scrub: 1,
        snap: {
          snapTo: "labels",
          duration: { min: 0.2, max: 0.5 },
          delay: 0.1,
          ease: "power1.inOut"
        }
      }
    });

    // We start at Label 1 with the first items already visible
    tl.addLabel("step1")
      
      // 2. Reveal Second Set (Image 3 + Text Three) TOGETHER
      // Based on your HTML, Image 3 is "REAL"
      .to("#image3", { opacity: 1, duration: 0.8 }, "+=0.2")
      .to(".dt-in.three", { opacity: 1, duration: 0.8 }, "<") 
      .addLabel("step2")
      
      // 3. Reveal Third Set (Image 2 + Text Two) TOGETHER
      // Based on your HTML, Image 2 is "ROAR"
      .to("#image2", { opacity: 1, duration: 0.8 }, "+=0.2")
      .to(".dt-in.two", { opacity: 1, duration: 0.8 }, "<")
      .addLabel("step3")
      
      // 4. Reveal Final Set (Button)
      .to(".dt-in.four", { opacity: 1, duration: 0.8 }, "+=0.2")
      .addLabel("step4");

    window.addEventListener("resize", ScrollTrigger.refresh);

    return () => {
      window.removeEventListener("resize", ScrollTrigger.refresh);
      tl.scrollTrigger && tl.scrollTrigger.kill();
      tl.kill();
    };
  });
}
          });
      </script>


    <script>
      {% if template.name == 'index' %}
        (function() {
          let loaderDismissed = false;

          const hideLoader = () => {
            if (loaderDismissed) return;
            loaderDismissed = true;

            document.documentElement.classList.remove('show-home-loader');
            document.documentElement.classList.add('home-loader-done');

            try {
              sessionStorage.setItem('homepageLoaderSeen', 'true');
            } catch (e) {}

            window.setTimeout(() => {
              const loader = document.getElementById('homepage-loader');
              if (loader) {
                loader.remove();
              }
            }, 500);
          };

          const shouldShowLoader = document.documentElement.classList.contains('show-home-loader');

          if (shouldShowLoader) {
            window.addEventListener('load', hideLoader, { once: true });
            window.setTimeout(hideLoader, 5000);
          }
        })();
      {% endif %}

          AOS.init();
    </script>

