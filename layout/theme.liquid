          function playCenterVideo() {
  // 1. Pause all videos first
  document.querySelectorAll(".vcitem-video video").forEach(v => v.pause());

  // 2. Find the video inside the current center slide and play it
  const centerVideo = document.querySelector(".owl-item.center video");
  if (centerVideo) {
    centerVideo.muted = true; // Required for browser autoplay permissions
    centerVideo.play().catch(e => console.log("Autoplay prevented:", e));
  }
}

